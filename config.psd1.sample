@{
    # Paths
    LlamaCppDir  = "C:\Users\emili\OneDrive\git\llama.cpp"
    OpenSSLDir   = "C:\Program Files\OpenSSL-Win64"
    HipPath      = "C:\Program Files\AMD\ROCm\7.1"
    VsDevShell   = "C:\Program Files\Microsoft Visual Studio\18\Community\Common7\Tools\Launch-VsDevShell.ps1"
    CacheDir     = "E:\llama.cpp\models"
    OpenWebUIDir = ".\open-webui"

    # Build settings
