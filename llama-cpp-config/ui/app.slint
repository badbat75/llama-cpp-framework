// llama.cpp-framework configurator — Slint UI.
//
// Left navigation rail (Server / Models / Integrations) and a content area that swaps
// pages via `AppState.current_tab`. Live server status is shown in the footer.
//
// All shared data/callbacks live in `AppState` (state.slint); this file is just
// the window shell and the tray. Rust drives everything via `app.global::<AppState>()`.

import { LineEdit, Button, ListView, Palette } from "std-widgets.slint";
import { AppState } from "state.slint";
import { Tokens, ModalOverlay } from "components.slint";
// Re-export so Slint generates the Rust accessor (`app.global::<AppState>()`);
// a bare import wouldn't surface it to Rust.
export { AppState }
import { ServerPage } from "server_page.slint";
import { ModelsPage } from "models_page.slint";
import { IntegrationsPage } from "integrations_page.slint";

// ── Nav rail item ──────────────────────────────

component NavItem inherits Rectangle {
    in property <string> label;
    in property <string> glyph;
    in property <bool> selected;
    callback clicked;

    // Surface the rail item to assistive tech — a bare Rectangle+TouchArea
    // is invisible to it.
    accessible-role: tab;
    accessible-label: root.label;
    accessible-checkable: true;
    accessible-checked: root.selected;

    height: 40px;
    border-radius: 6px;
    background: selected
        ? Palette.accent-background.transparentize(Tokens.sel)
        : (touch.has-hover ? Palette.alternate-background : transparent);

    if selected : Rectangle {
        x: 0; y: 8px; width: 3px; height: parent.height - 16px;
        border-radius: 1.5px;
        background: Palette.accent-background;
    }

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 12px;
        spacing: 12px;
        alignment: start;

        Text {
            text: root.glyph;
            font-family: "Segoe Fluent Icons";
            font-size: 16px;
            color: root.selected ? Palette.accent-background : Palette.foreground;
            vertical-alignment: center;
            width: 22px;
        }
        Text {
            text: root.label;
            font-size: 13px;
            font-weight: root.selected ? 600 : 400;
            color: Palette.foreground;
            vertical-alignment: center;
        }
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

export component AppWindow inherits Window {
    title: AppState.app_version == ""
        ? "llama.cpp-framework configurator"
        : "llama.cpp-framework configurator v" + AppState.app_version;
    icon: @image-url("llama.png");
    // Keep the floor low enough that the whole window — including the Save/Revert
    // row at the bottom of each scrolling page — fits on a 1366×768 laptop after
    // the title bar and taskbar. The preferred size stays roomy on big screens.
    min-width: 820px;
    min-height: 520px;
    preferred-width: 1080px;
    preferred-height: 760px;
    background: Palette.background;
    // Give the shortcut FocusScope focus on startup so KeyBindings fire before
    // the user clicks into any widget.
    forward-focus: shortcuts;

    shortcuts := FocusScope {
        width: 100%;
        height: 100%;

        // ─── Keyboard shortcuts (app-wide; events bubble up to this scope) ──
        // Every binding gates on !modal_open: while a dialog is up, saving the
        // page behind the backdrop, switching tabs, or stacking a second dialog
        // would act on UI the user can't see. Esc inside ModalOverlay dismisses.
        KeyBinding {
            keys: @keys(Control + S);
            activated => {
                if (AppState.modal_open) { return; }
                // Same gating as the Save buttons — both read the can_save_*
                // properties in state.slint so the conditions can't drift.
                if (AppState.current_tab == 0 && AppState.can_save_server) { AppState.save_server(); }
                else if (AppState.current_tab == 1 && AppState.can_save_preset) { AppState.save_preset(); }
                else if (AppState.current_tab == 2) { AppState.save_integrations(); }
            }
        }
        KeyBinding { keys: @keys(Control + "1"); activated => { if (!AppState.modal_open) { AppState.current_tab = 0; } } }
        KeyBinding { keys: @keys(Control + "2"); activated => { if (!AppState.modal_open) { AppState.current_tab = 1; } } }
        KeyBinding { keys: @keys(Control + "3"); activated => { if (!AppState.modal_open) { AppState.current_tab = 2; } } }
        KeyBinding { keys: @keys(F5); activated => { if (!AppState.modal_open) { AppState.refresh_status(); } } }
        KeyBinding { keys: @keys(Control + N); activated => { if (!AppState.modal_open) { AppState.new_preset(); } } }

    VerticalLayout {
        width: 100%;
        height: 100%;
        spacing: 0px;

        // ─── Body: nav rail | content ─────────────────────────────
        HorizontalLayout {
            spacing: 0px;
            vertical-stretch: 1;

            // Nav rail
            Rectangle {
                width: 200px;
                background: Palette.background;
                Rectangle {
                    x: parent.width - 1px;
                    width: 1px;
                    background: Palette.border;
                }
                VerticalLayout {
                    padding: 12px;
                    spacing: 4px;

                    NavItem {
                        glyph: "\u{E713}";
                        label: "Server";
                        selected: AppState.current_tab == 0;
                        clicked => { AppState.current_tab = 0; }
                    }
                    NavItem {
                        glyph: "\u{EB9F}";
                        label: "Models";
                        selected: AppState.current_tab == 1;
                        clicked => { AppState.current_tab = 1; }
                    }
                    NavItem {
                        glyph: "\u{E943}";
                        label: "Integrations";
                        selected: AppState.current_tab == 2;
                        clicked => { AppState.current_tab = 2; }
                    }

                    // Spacer pushes the server controls to the bottom of the rail.
                    Rectangle { vertical-stretch: 1; }

                    // ── Server controls ──────────────────────────────
                    // Start/Stop stacked over Open chat UI over Refresh. Live
                    // status drives which of Start/Stop shows; Open chat UI is
                    // enabled only while the server is running.
                    VerticalLayout {
                        spacing: 8px;
                        // Transitional state: Stop was triggered but the process
                        // (and its GPU context) is still tearing down.
                        if AppState.server_stopping : Button {
                            text: "Stopping…";
                            enabled: false;
                        }
                        if !AppState.server_stopping && AppState.server_running : Button {
                            text: "Stop";
                            clicked => { AppState.stop_server(); }
                        }
                        if !AppState.server_stopping && !AppState.server_running : Button {
                            text: "Start";
                            primary: true;
                            clicked => { AppState.start_server(); }
                        }
                        Button {
                            text: "Open chat UI";
                            enabled: AppState.server_running && !AppState.server_stopping;
                            // server_form_base, not server_form: the running server
                            // listens on the SAVED port (runstate reads server.ini),
                            // not on an unsaved edit of the port field.
                            clicked => { Platform.open-url("http://localhost:" + AppState.server_form_base.port); }
                        }
                        // Re-read the config files and re-scan the models
                        // directory. Always available — use it after adding a
                        // model file or hand-editing server.ini / presets.ini.
                        Button {
                            text: "Refresh";
                            clicked => { AppState.reload_all(); }
                        }
                    }
                }
            }

            // Content area
            Rectangle {
                horizontal-stretch: 1;
                background: Palette.background;

                VerticalLayout {
                    if AppState.current_tab == 0 : ServerPage { }
                    if AppState.current_tab == 1 : ModelsPage { }
                    if AppState.current_tab == 2 : IntegrationsPage { }
                }
            }
        }

        // ─── Footer status bar ──────────────────────────────────────
        // One HorizontalLayout: the status message stretches and elides so a
        // long error can never underlap the version / run-state cells.
        Rectangle {
            height: 32px;
            horizontal-stretch: 1;
            background: Palette.alternate-background;
            Rectangle {
                y: 0;
                height: 1px;
                background: Palette.border;
            }
            HorizontalLayout {
                padding-left: 16px;
                padding-right: 16px;
                spacing: 12px;

                // Messages (left). Always present so the layout keeps its
                // stretch cell even while the text is empty.
                Text {
                    text: AppState.status_text;
                    color: AppState.status_is_error ? Tokens.err : Palette.foreground;
                    font-size: 12px;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                    overflow: elide;
                }

                // llama-server version (left of the run state).
                if AppState.server_version != "" : Text {
                    text: "llama-server " + AppState.server_version;
                    font-size: 12px;
                    vertical-alignment: center;
                    color: Palette.foreground.transparentize(Tokens.faint);
                }

                // Run state + colored dot (right).
                Text {
                    text: AppState.server_status_is_error ? "Error"
                        : (AppState.server_running ? "Running" : "Stopped");
                    font-size: 12px;
                    vertical-alignment: center;
                    color: Palette.foreground.transparentize(Tokens.muted);
                }
                Rectangle {
                    width: 8px;
                    Rectangle {
                        y: (parent.height - self.height) / 2;
                        width: 8px;
                        height: 8px;
                        border-radius: 4px;
                        background: AppState.server_status_is_error ? Tokens.err
                            : (AppState.server_running ? Tokens.ok : Tokens.off);
                    }
                }
            }
        }

    } // /main VerticalLayout

    // ─── Overlay modals ────────────────────────────────────────────────
    // Direct children of the FocusScope, declared AFTER the body layout (plus
    // ModalOverlay's z:1) so they stack on top of it. They must NOT live inside
    // the VerticalLayout: a 100%×100% overlay allocated as a layout ROW would
    // squeeze the nav/content row and footer while open, and if the layout
    // compressed the overlay instead, the backdrop would no longer cover the
    // footer — leaving UI clickable under an "open" modal.
    if AppState.show_new_kind_picker: ModalOverlay {
        title: AppState.new_dialog_source_id == "" ? "New preset" : "Clone preset";
        description: AppState.new_dialog_source_id == ""
            ? "Pick the model for the new preset from your ModelsDir. It is created with default parameters."
            : "Cloning [" + AppState.new_dialog_source_id + "] → pick the target model from your ModelsDir. The new preset copies every parameter from [" + AppState.new_dialog_source_id + "] onto the model you pick.";
        card_width: 520px;
        card_height: 480px;
        dismissed => { AppState.show_new_kind_picker = false; }

        LineEdit {
            placeholder-text: "Filter models…";
            input-type: search;
            text <=> AppState.dialog_filter;
            edited(t) => { AppState.filter_dialog_models(t); }
            // Type-to-filter immediately when the dialog opens.
            init => { self.focus(); }
        }
        Rectangle {
            border-width: 1px;
            border-color: Palette.border;
            border-radius: 8px;
            background: Palette.alternate-background;
            vertical-stretch: 1;
            if AppState.dialog_model_labels.length == 0 : Text {
                x: 16px;
                y: 16px;
                width: parent.width - 32px;
                text: "No .gguf files found under ModelsDir. Drop files there and reopen this dialog.";
                wrap: word-wrap;
                font-size: 12px;
                color: Palette.foreground.transparentize(Tokens.muted);
            }
            ListView {
                for label[i] in AppState.dialog_model_labels : Rectangle {
                    accessible-role: list-item;
                    accessible-label: label;
                    height: 32px;
                    background: i == AppState.dialog_model_index
                        ? Palette.accent-background.transparentize(Tokens.sel)
                        : (touch.has-hover ? Palette.background : transparent);
                    if i == AppState.dialog_model_index : Rectangle {
                        x: 0; y: 4px; width: 3px; height: parent.height - 8px;
                        border-radius: 1.5px;
                        background: Palette.accent-background;
                    }
                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        Text {
                            text: label;
                            font-size: 12px;
                            color: Palette.foreground;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                    }
                    touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { AppState.dialog_model_index = i; }
                    }
                }
            }
        }
        HorizontalLayout {
            spacing: 8px;
            alignment: end;
            Button {
                text: "Cancel";
                clicked => { AppState.show_new_kind_picker = false; }
            }
            Button {
                text: AppState.new_dialog_source_id == "" ? "Create" : "Clone";
                primary: true;
                enabled: AppState.dialog_model_index >= 0;
                clicked => {
                    AppState.show_new_kind_picker = false;
                    if (AppState.new_dialog_source_id == "") {
                        AppState.pick_new_empty();
                    } else {
                        AppState.pick_new_clone();
                    }
                }
            }
        }
    }

    if AppState.show_rename_dialog: ModalOverlay {
        title: "Rename preset";
        description: "Renaming [" + AppState.rename_old_id + "]. This only changes the section header in presets.ini; every parameter inside is preserved.";
        dismissed => { AppState.show_rename_dialog = false; }

        LineEdit {
            text <=> AppState.rename_new_id;
            placeholder-text: "New id";
            init => { self.focus(); }
            accepted(t) => {
                if (t != "" && t != AppState.rename_old_id) {
                    AppState.show_rename_dialog = false;
                    AppState.rename_preset(AppState.rename_old_id, t);
                }
            }
        }
        Rectangle { vertical-stretch: 1; }
        HorizontalLayout {
            spacing: 8px;
            alignment: end;
            Button {
                text: "Cancel";
                clicked => { AppState.show_rename_dialog = false; }
            }
            Button {
                text: "Rename";
                primary: true;
                enabled: AppState.rename_new_id != "" && AppState.rename_new_id != AppState.rename_old_id;
                clicked => {
                    AppState.show_rename_dialog = false;
                    AppState.rename_preset(AppState.rename_old_id, AppState.rename_new_id);
                }
            }
        }
    }
    } // /shortcuts FocusScope
} // End of AppWindow

// ── System tray ──────────────────────────────────────────────────────
// Separate root component (instantiated alongside AppWindow in gui.rs). Left-click
// reopens the window; right-click (Windows) opens the menu. `server_running` is kept
// in sync from Rust so the hover tooltip reflects live status.
export component AppTray inherits SystemTrayIcon {
    in property <bool> server_running;
    // Swap to the green-dotted icon while the server is up (both PNGs are
    // generated by build.rs). The icon property is change-tracked, so this
    // updates the tray live as the status flips.
    icon: root.server_running ? @image-url("llama-on.png") : @image-url("llama.png");
    tooltip: root.server_running ? "llama.cpp — server running" : "llama.cpp — server stopped";
    callback open_window();
    callback start_server();
    callback stop_server();
    callback quit_app();
    clicked => { root.open_window(); }
    Menu {
        MenuItem { title: "Open configurator"; activated => { root.open_window(); } }
        MenuSeparator { }
        // Start only when stopped; Stop only when running. The menu tree is
        // reactive, so it rebuilds when server_running changes.
        if !root.server_running : MenuItem { title: "Start server"; activated => { root.start_server(); } }
        if root.server_running : MenuItem { title: "Stop server"; activated => { root.stop_server(); } }
        MenuSeparator { }
        MenuItem { title: "Quit"; activated => { root.quit_app(); } }
    }
}
