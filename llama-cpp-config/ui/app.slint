// llama.cpp-framework configurator — Slint UI.
//
// Left navigation rail (Server / Models / Integrations) and a content area that swaps
// pages via `current_tab`. Live server status is shown in the footer.

import { LineEdit, ComboBox, CheckBox, Button, ListView, ScrollView, Palette, RadioGroup } from "std-widgets.slint";


export struct PresetSummary {
    id: string,
    model: string,
    // Set by the Rust-side preset filter; `false` rows are hidden in the list
    // while keeping the row index stable (so select_preset(i) still maps to the
    // full presets vector).
    visible: bool,
}

export struct PresetForm {
    id: string,
    model: string,
    mmproj: string,
    model_draft: string,
    spec_type: string,
    spec_draft_n_max: string,
    n_gpu_layers_draft: string,
    device_draft: string,
    device: string,
    ctx_size: int,
    n_gpu_layers: int,
    parallel: int,
    batch_size: int,
    ubatch_size: int,
    cache_type_k: string,
    cache_type_v: string,
    flash_attn: bool,
    cache_ram: int,
    jinja: bool,
    reasoning: string,
    reasoning_format: string,
    n_cpu_moe: string,
    temp: string,
    top_k: string,
    top_p: string,
    min_p: string,
    repeat_penalty: string,
    presence_penalty: string,
    chat_template_kwargs: string,
}

export struct IntegrationModel {
    id: string,
    label: string,
    enabled: bool,
}

// ── Reusable visual pieces ───────────────────────────────────────────────

component NavItem inherits Rectangle {
    in property <string> label;
    in property <string> glyph;
    in property <bool> selected;
    callback clicked;

    height: 40px;
    border-radius: 6px;
    background: selected
        ? Palette.accent-background.transparentize(0.82)
        : (touch.has-hover ? Palette.alternate-background : transparent);

    if selected : Rectangle {
        x: 0; y: 8px; width: 3px; height: parent.height - 16px;
        border-radius: 1.5px;
        background: Palette.accent-background;
    }

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 12px;
        spacing: 12px;
        alignment: start;

        Text {
            text: root.glyph;
            font-family: "Segoe Fluent Icons";
            font-size: 16px;
            color: root.selected ? Palette.accent-background : Palette.foreground;
            vertical-alignment: center;
            width: 22px;
        }
        Text {
            text: root.label;
            font-size: 13px;
            font-weight: root.selected ? 600 : 400;
            color: Palette.foreground;
            vertical-alignment: center;
        }
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

component SectionCard {
    in property <string> heading;
    in property <length> content_spacing: 10px;
    in property <length> content_padding: 16px;

    VerticalLayout {
        spacing: 8px;

        if root.heading != "" : Text {
            text: root.heading;
            font-size: 13px;
            font-weight: 600;
            color: Palette.foreground;
        }

        Rectangle {
            border-radius: 8px;
            border-width: 1px;
            border-color: Palette.border;
            background: Palette.alternate-background;
            // Subtle elevation (Skia renderer only).
            drop-shadow-color: #00000022;
            drop-shadow-blur: 10px;
            drop-shadow-offset-y: 2px;

            VerticalLayout {
                padding: root.content_padding;
                spacing: root.content_spacing;
                @children
            }
        }
    }
}

component LabeledField inherits HorizontalLayout {
    in property <string> label;
    // Optional hover help. When set, an ⓘ glyph is shown after the label and
    // carries a Tooltip — keeps long explanations out of the input placeholders.
    in property <string> hint;
    in property <length> label_width: 130px;
    spacing: 8px;
    alignment: stretch;
    HorizontalLayout {
        width: root.label_width;
        spacing: 4px;
        alignment: start;
        Text {
            text: root.label;
            vertical-alignment: center;
            font-size: 13px;
            // Elide instead of overflowing onto the field when the label is long;
            // horizontal-stretch lets the ⓘ keep its own cell on the right.
            overflow: elide;
            horizontal-stretch: 1;
        }
        if root.hint != "" : Text {
            text: "\u{E946}";
            font-family: "Segoe Fluent Icons";
            font-size: 13px;
            // Fixed-width cell so the glyph is always visible and gives the
            // Tooltip a reliable hover target — inside a 130px label row a
            // stretched/0-width cell would collapse and never trigger hover.
            width: 16px;
            horizontal-stretch: 0;
            horizontal-alignment: center;
            vertical-alignment: center;
            color: Palette.foreground.transparentize(0.45);
            // Custom content (a plain Text) avoids the styled-text/@markdown
            // conversion that Tooltip.text would require for a string property.
            // It MUST be wrapped in a layout: ToolTipImpl is a plain Rectangle
            // and does not lay out a bare fixed-width child, so the popup stays
            // ~padding-wide and the text spills off its right edge. A layout
            // propagates the 300px width up so the Rectangle sizes to it.
            Tooltip {
                VerticalLayout {
                    padding: 10px;
                    Text { text: root.hint; wrap: word-wrap; width: 300px; font-size: 14px; }
                }
            }
        }
    }
    @children
}

export component AppWindow inherits Window {
    title: "llama.cpp-framework configurator";
    icon: @image-url("llama.png");
    min-width: 1000px;
    min-height: 700px;
    preferred-width: 1180px;
    preferred-height: 880px;
    background: Palette.background;
    // Give the shortcut FocusScope focus on startup so KeyBindings fire before
    // the user clicks into any widget.
    forward-focus: shortcuts;

    // ── Navigation ───────────────────────────────────────────────────
    // 0 = Server, 1 = Models, 2 = Integrations.
    in-out property <int> current_tab: 0;

    // ── Live status ──────────────────────────────────────────────────
    in property <bool> server_running: false;
    in-out property <bool> server_status_is_error: false;
    in property <string> server_version: "";
    in property <string> server_command_line: "";

    // ── Server tab state ─────────────────────────────────────────────
    in-out property <string> server_port: "8080";
    in-out property <string> server_hostname: "localhost";
    in-out property <[string]> bind_labels;
    in-out property <[string]> bind_values;
    in-out property <int> bind_index: 0;
    in-out property <bool> server_mlock: true;
    in-out property <string> server_threads: "";
    in-out property <string> server_cache_reuse: "";
    in-out property <string> server_threads_batch: "";
    in-out property <string> server_models_max: "";
    in-out property <string> server_models_dir: "";
    in-out property <string> server_device: "";

    // Baseline snapshot of the loaded server config (set by Rust on load/save).
    // `server_dirty` is true while any field differs — drives Save/Revert enabled.
    in-out property <string> server_port_base;
    in-out property <string> server_hostname_base;
    in-out property <bool> server_mlock_base;
    in-out property <string> server_threads_base;
    in-out property <string> server_cache_reuse_base;
    in-out property <string> server_threads_batch_base;
    in-out property <string> server_models_max_base;
    in-out property <string> server_models_dir_base;
    in-out property <string> server_device_base;
    out property <bool> server_dirty:
        root.server_port != root.server_port_base
        || root.server_hostname != root.server_hostname_base
        || root.server_mlock != root.server_mlock_base
        || root.server_threads != root.server_threads_base
        || root.server_cache_reuse != root.server_cache_reuse_base
        || root.server_threads_batch != root.server_threads_batch_base
        || root.server_models_max != root.server_models_max_base
        || root.server_models_dir != root.server_models_dir_base
        || root.server_device != root.server_device_base;

    // GPU device enumeration (parsed from `llama-server --list-devices`).
    // `all_device_*` is the cached raw list filled by the async probe; the
    // per-combobox *_labels/_values/_index triples are derived from it.
    in-out property <[string]> all_device_ids;
    in-out property <[string]> all_device_labels;
    in-out property <[string]> server_dev_labels;
    in-out property <[string]> server_dev_values;
    in-out property <int> server_dev_index: 0;
    in-out property <[string]> pdev_labels;
    in-out property <[string]> pdev_values;
    in-out property <int> pdev_index: 0;
    in-out property <[string]> pdraft_labels;
    in-out property <[string]> pdraft_values;
    in-out property <int> pdraft_index: 0;

    // ── Models tab state ─────────────────────────────────────────────
    in-out property <[PresetSummary]> presets;
    in-out property <int> selected_preset_index: -1;
    in-out property <PresetForm> form;
    // Baseline snapshot of the loaded preset (set by Rust whenever the form is
    // (re)loaded or saved). Struct inequality drives Save/Revert enabled.
    in-out property <PresetForm> form_base;
    out property <bool> preset_dirty: root.form != root.form_base;
    in-out property <string> presets_path: "";
    in-out property <string> presets_filter: "";

    // File-field dropdowns for model and mmproj
    in-out property <[string]> model_labels;
    in-out property <[string]> model_values;
    in-out property <int> model_index: -1;
    in-out property <[string]> mmproj_labels;
    in-out property <[string]> mmproj_values;
    in-out property <int> mmproj_index: -1;
    // Unified draft-model picker (MTP heads from mtps\ + DFlash drafters from
    // dflashs\). `draft_specs[i]` is the --spec-type to apply when row i is picked.
    in-out property <[string]> draft_labels;
    in-out property <[string]> draft_values;
    in-out property <[string]> draft_specs;
    in-out property <int> draft_index: -1;

    // ── New-preset dialog state ─────────────────────────────────────
    in-out property <bool> show_new_kind_picker: false;
    in-out property <string> new_dialog_source_id: "";
    in-out property <[string]> dialog_model_labels;
    in-out property <[string]> dialog_model_values;
    in-out property <int> dialog_model_index: -1;
    in-out property <string> dialog_filter: "";

    // ── Rename-preset dialog state ──────────────────────────────────
    in-out property <bool> show_rename_dialog: false;
    in-out property <string> rename_old_id: "";
    in-out property <string> rename_new_id: "";

    // ── Integrations tab state ─────────────────────────────────────
    in-out property <string> integration_base_url: "";
    in-out property <[IntegrationModel]> integration_models;
    in-out property <bool> integration_provider_active: false;
    in-out property <string> integration_claude_env: "";

    // ── Status / toast ───────────────────────────────────────────────
    in-out property <string> status_text: "";
    in-out property <bool> status_is_error: false;

    // ── Callbacks ────────────────────────────────────────────────────
    callback save_server();
    callback revert_server();
    callback browse_models_dir(string) -> string;

    callback select_preset(int);
    callback save_preset();
    callback revert_preset();
    callback delete_preset(string);
    callback new_preset();
    callback pick_new_empty();
    callback pick_new_clone();
    callback rename_preset(string, string);
    callback filter_presets(string);
    callback filter_dialog_models(string);

    callback refresh_status();
    callback start_server();
    callback stop_server();
    // Recompute the device dropdown indices after the form is mutated in-UI
    // (e.g. the MTP picker auto-filling the draft device).
    callback sync_device_dropdowns();

    callback toggle_integration_model(int);
    callback save_integrations();
    callback revert_integrations();

    shortcuts := FocusScope {
        width: 100%;
        height: 100%;

        // ─── Keyboard shortcuts (app-wide; events bubble up to this scope) ──
        KeyBinding {
            keys: @keys(Control + S);
            activated => {
                if (root.current_tab == 0) { root.save_server(); }
                else if (root.current_tab == 1 && root.selected_preset_index >= 0 && root.form.id != "") { root.save_preset(); }
                else if (root.current_tab == 2) { root.save_integrations(); }
            }
        }
        KeyBinding { keys: @keys(Control + "1"); activated => { root.current_tab = 0; } }
        KeyBinding { keys: @keys(Control + "2"); activated => { root.current_tab = 1; } }
        KeyBinding { keys: @keys(Control + "3"); activated => { root.current_tab = 2; } }
        KeyBinding { keys: @keys(F5); activated => { root.refresh_status(); } }
        KeyBinding { keys: @keys(Control + N); activated => { root.new_preset(); } }

    VerticalLayout {
        width: 100%;
        height: 100%;
        spacing: 0px;

        // ─── Overlay modals ────────────────────────────────────────────
        if root.show_new_kind_picker: Rectangle {
            z: 1;
            width: 100%;
            height: 100%;
            background: #000000.transparentize(0.45);
            TouchArea {
                clicked => { root.show_new_kind_picker = false; }
            }
            Rectangle {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                width: 520px;
                height: 480px;
                background: Palette.background;
                border-radius: 10px;
                border-width: 1px;
                border-color: Palette.border;
                drop-shadow-color: #00000066;
                drop-shadow-blur: 24px;
                drop-shadow-offset-y: 6px;
                TouchArea { }
                VerticalLayout {
                    padding: 22px;
                    spacing: 12px;
                    Text {
                        text: "New preset";
                        font-size: 16px;
                        font-weight: 700;
                        color: Palette.foreground;
                    }
                    Text {
                        text: root.new_dialog_source_id == ""
                            ? "Pick a model from your ModelsDir. The new preset will be created with default parameters."
                            : "Pick a model from your ModelsDir. \"Empty\" creates a preset with default parameters; \"Clone\" copies every parameter of [" + root.new_dialog_source_id + "] onto the picked model.";
                        wrap: word-wrap;
                        font-size: 12px;
                        color: Palette.foreground.transparentize(0.25);
                    }
                    LineEdit {
                        placeholder-text: "Filter models…";
                        input-type: search;
                        text: root.dialog_filter;
                        edited(t) => { root.dialog_filter = t; root.filter_dialog_models(t); }
                    }
                    Rectangle {
                        border-width: 1px;
                        border-color: Palette.border;
                        border-radius: 8px;
                        background: Palette.alternate-background;
                        vertical-stretch: 1;
                        if root.dialog_model_labels.length == 0 : Text {
                            x: 16px;
                            y: 16px;
                            width: parent.width - 32px;
                            text: "No .gguf files found under ModelsDir. Drop files there and reopen this dialog.";
                            wrap: word-wrap;
                            font-size: 12px;
                            color: Palette.foreground.transparentize(0.4);
                        }
                        ListView {
                            for label[i] in root.dialog_model_labels : Rectangle {
                                height: 32px;
                                background: i == root.dialog_model_index
                                    ? Palette.accent-background.transparentize(0.82)
                                    : (touch.has-hover ? Palette.background : transparent);
                                if i == root.dialog_model_index : Rectangle {
                                    x: 0; y: 4px; width: 3px; height: parent.height - 8px;
                                    border-radius: 1.5px;
                                    background: Palette.accent-background;
                                }
                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 12px;
                                    Text {
                                        text: label;
                                        font-size: 12px;
                                        color: Palette.foreground;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                }
                                touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.dialog_model_index = i; }
                                }
                            }
                        }
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        alignment: end;
                        Button {
                            text: "Cancel";
                            clicked => { root.show_new_kind_picker = false; }
                        }
                        Button {
                            text: root.new_dialog_source_id == "" ? "Create" : "Empty";
                            enabled: root.dialog_model_index >= 0;
                            clicked => {
                                root.show_new_kind_picker = false;
                                root.pick_new_empty();
                            }
                        }
                        if root.new_dialog_source_id != "" : Button {
                            text: "Clone…";
                            enabled: root.dialog_model_index >= 0;
                            clicked => {
                                root.show_new_kind_picker = false;
                                root.pick_new_clone();
                            }
                        }
                    }
                }
            }
        }

        if root.show_rename_dialog: Rectangle {
            z: 1;
            width: 100%;
            height: 100%;
            background: #000000.transparentize(0.45);
            TouchArea {
                clicked => { root.show_rename_dialog = false; }
            }
            Rectangle {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                width: 440px;
                height: 220px;
                background: Palette.background;
                border-radius: 10px;
                border-width: 1px;
                border-color: Palette.border;
                drop-shadow-color: #00000066;
                drop-shadow-blur: 24px;
                drop-shadow-offset-y: 6px;
                TouchArea { }
                VerticalLayout {
                    padding: 22px;
                    spacing: 12px;
                    Text {
                        text: "Rename preset";
                        font-size: 16px;
                        font-weight: 700;
                        color: Palette.foreground;
                    }
                    Text {
                        text: "Renaming [" + root.rename_old_id + "]. This only changes the section header in presets.ini; every parameter inside is preserved.";
                        wrap: word-wrap;
                        font-size: 12px;
                        color: Palette.foreground.transparentize(0.25);
                    }
                    LineEdit {
                        text: root.rename_new_id;
                        placeholder-text: "New id";
                        edited(t) => { root.rename_new_id = t; }
                        accepted(t) => {
                            root.rename_new_id = t;
                            if (t != "" && t != root.rename_old_id) {
                                root.show_rename_dialog = false;
                                root.rename_preset(root.rename_old_id, t);
                            }
                        }
                    }
                    Rectangle { vertical-stretch: 1; }
                    HorizontalLayout {
                        spacing: 8px;
                        alignment: end;
                        Button {
                            text: "Cancel";
                            clicked => { root.show_rename_dialog = false; }
                        }
                        Button {
                            text: "Rename";
                            primary: true;
                            enabled: root.rename_new_id != "" && root.rename_new_id != root.rename_old_id;
                            clicked => {
                                root.show_rename_dialog = false;
                                root.rename_preset(root.rename_old_id, root.rename_new_id);
                            }
                        }
                    }
                }
            }
        }

        // ─── Body: nav rail | content ─────────────────────────────
        HorizontalLayout {
            spacing: 0px;
            vertical-stretch: 1;

            // Nav rail
            Rectangle {
                width: 200px;
                background: Palette.background;
                Rectangle {
                    x: parent.width - 1px;
                    width: 1px;
                    background: Palette.border;
                }
                VerticalLayout {
                    padding: 12px;
                    spacing: 4px;
                    alignment: start;

                    NavItem {
                        glyph: "\u{E713}";
                        label: "Server";
                        selected: root.current_tab == 0;
                        clicked => { root.current_tab = 0; }
                    }
                    NavItem {
                        glyph: "\u{EB9F}";
                        label: "Models";
                        selected: root.current_tab == 1;
                        clicked => { root.current_tab = 1; }
                    }
                    NavItem {
                        glyph: "\u{E943}";
                        label: "Integrations";
                        selected: root.current_tab == 2;
                        clicked => { root.current_tab = 2; }
                    }
                    }
                }

            // Content area
            Rectangle {
                horizontal-stretch: 1;
                background: Palette.background;

                VerticalLayout {

                // ─────────────── Page 0: Server ───────────────
                if root.current_tab == 0 : ScrollView {
                    VerticalLayout {
                        padding: 24px;
                        spacing: 16px;
                        alignment: start;

                        Text {
                            text: "Server";
                            font-size: 22px;
                            font-weight: 600;
                            color: Palette.foreground;
                        }
                        Text {
                            text: "Machine-wide llama-server settings (server.ini). Per-model knobs live under Models.";
                            color: Palette.foreground.transparentize(0.4);
                            font-size: 12px;
                            wrap: word-wrap;
                        }

                        SectionCard {
                            heading: "Network";
                            LabeledField {
                                label: "Port";
                                hint: "TCP port llama-server listens on (--port). Default 8080 — the chat UI and integrations connect here.";
                                LineEdit {
                                    text: root.server_port;
                                    input-type: number;
                                    placeholder-text: "8080";
                                    edited(t) => { root.server_port = t; }
                                }
                            }
                            LabeledField {
                                label: "Bind to";
                                hint: "Interface to bind (--host). localhost = this PC only; 0.0.0.0 = all interfaces, reachable from the LAN.";
                                ComboBox {
                                    model: root.bind_labels;
                                    current-index: root.bind_index;
                                    selected(value) => {
                                        let i = self.current-index;
                                        root.bind_index = i;
                                        if (i >= 0 && i < root.bind_values.length) {
                                            root.server_hostname = root.bind_values[i];
                                        }
                                    }
                                }
                            }
                        }

                        SectionCard {
                            heading: "Resources";
                            LabeledField {
                                label: "Mlock (lock RAM)";
                                hint: "Locks model weights into physical RAM (--mlock) so the OS can't page them out. Keeps latency stable; needs enough free RAM for the whole model.";
                                CheckBox {
                                    text: "lock model in physical RAM";
                                    checked: root.server_mlock;
                                    toggled => { root.server_mlock = self.checked; }
                                }
                            }
                            LabeledField {
                                label: "CPU threads";
                                hint: "--threads: CPU threads for generation. Blank = half the physical-core count; more won't help once GPU-bound.";
                                LineEdit {
                                    text: root.server_threads;
                                    input-type: number;
                                    placeholder-text: "blank = half the physical-core count";
                                    edited(t) => { root.server_threads = t; }
                                }
                            }
                            LabeledField {
                                label: "Cache reuse";
                                hint: "--cache-reuse: minimum prefix length (tokens) the server reuses from the KV cache across requests, skipping re-prefill. Higher saves compute on shared prefixes.";
                                LineEdit {
                                    text: root.server_cache_reuse;
                                    input-type: number;
                                    placeholder-text: "256";
                                    edited(t) => { root.server_cache_reuse = t; }
                                }
                            }
                            LabeledField {
                                label: "Batch threads";
                                hint: "--threads-batch: CPU threads for prompt processing (prefill). Blank = ~75% of cores.";
                                LineEdit {
                                    text: root.server_threads_batch;
                                    input-type: number;
                                    placeholder-text: "blank = 75% of cores";
                                    edited(t) => { root.server_threads_batch = t; }
                                }
                            }
                            LabeledField {
                                label: "Max models";
                                hint: "--models-max: how many preset models llama-server keeps resident at once. 1 = load one at a time (lowest VRAM); higher lets it hot-swap without reloading.";
                                LineEdit {
                                    text: root.server_models_max;
                                    input-type: number;
                                    placeholder-text: "1 (one at a time)";
                                    edited(t) => { root.server_models_max = t; }
                                }
                            }
                            LabeledField {
                                label: "Models folder";
                                hint: "Root folder scanned for GGUFs. Pickers read its subfolders: models\\, mmprojs\\, mtps\\, dflashs\\.";
                                LineEdit {
                                    text: root.server_models_dir;
                                    placeholder-text: "root dir (models\\ and mmprojs\\ underneath)";
                                    edited(t) => { root.server_models_dir = t; }
                                }
                                Button {
                                    text: "Browse…";
                                    clicked => {
                                        root.server_models_dir = root.browse_models_dir(root.server_models_dir);
                                    }
                                }
                            }
                            LabeledField {
                                label: "GPU device";
                                hint: "Default GPU for all presets (--device, e.g. CUDA0). A per-preset GPU device overrides it. Blank = all detected devices.";
                                ComboBox {
                                    model: root.server_dev_labels;
                                    current-index <=> root.server_dev_index;
                                    selected(value) => {
                                        let i = self.current-index;
                                        if (i >= 0 && i < root.server_dev_values.length) {
                                            root.server_device = root.server_dev_values[i];
                                        }
                                    }
                                }
                            }
                        }

                        SectionCard {
                            heading: "Control";
                            content_padding: 12px;
                            HorizontalLayout {
                                spacing: 8px;
                                Rectangle {
                                    width: 130px;
                                    height: 34px;
                                    Text {
                                        x: 0;
                                        y: 0;
                                        height: 100%;
                                        vertical-alignment: center;
                                        text: root.server_running ? "Server is running" : "Server is stopped";
                                        font-size: 13px;
                                        color: root.server_running ? #2e7d32 : Palette.foreground.transparentize(0.45);
                                    }
                                }
                                HorizontalLayout {
                                    spacing: 12px;
                                    horizontal-stretch: 1;
                                    if root.server_running : Button {
                                        text: "Stop";
                                        primary: false;
                                        clicked => { root.stop_server(); }
                                    }
                                    if !root.server_running : Button {
                                        text: "Start";
                                        primary: true;
                                        clicked => { root.start_server(); }
                                    }
                                    Button {
                                        text: "Open chat UI";
                                        enabled: root.server_running;
                                        clicked => { Platform.open-url("http://localhost:" + root.server_port); }
                                    }
                                    LineEdit {
                                        text: root.server_command_line;
                                        read-only: true;
                                        horizontal-stretch: 1;
                                    }
                                }
                            }
                        }

                        HorizontalLayout {
                            alignment: end;
                            spacing: 8px;
                            Button {
                                text: "Revert";
                                enabled: root.server_dirty;
                                clicked => { root.revert_server(); }
                            }
                            Button {
                                text: "Save changes";
                                primary: true;
                                enabled: root.server_dirty;
                                clicked => { root.save_server(); }
                            }
                        }
                    }
                }

                // ─────────────── Page 1: Models ───────────────
                if root.current_tab == 1 : HorizontalLayout {
                    padding: 20px;
                    spacing: 16px;

                    // Left column: preset list
                    VerticalLayout {
                        width: 240px;
                        spacing: 10px;

                        Text {
                            text: "Presets";
                            font-size: 14px;
                            font-weight: 600;
                            color: Palette.foreground;
                        }

                        LineEdit {
                            placeholder-text: "Filter presets…";
                            input-type: search;
                            text: root.presets_filter;
                            edited(t) => { root.presets_filter = t; root.filter_presets(t); }
                        }

                        Rectangle {
                            border-width: 1px;
                            border-color: Palette.border;
                            border-radius: 8px;
                            background: Palette.alternate-background;
                            min-height: 280px;
                            vertical-stretch: 1;

                            ListView {
                                for p[i] in root.presets : Rectangle {
                                    // Filtered-out rows collapse to zero height; the index `i` stays
                                    // aligned with the full presets vector for select_preset(i).
                                    visible: p.visible;
                                    height: p.visible ? 36px : 0px;
                                    background: i == root.selected_preset_index
                                        ? Palette.accent-background.transparentize(0.82)
                                        : (item-touch.has-hover ? Palette.background : transparent);

                                    if i == root.selected_preset_index : Rectangle {
                                        x: 0; y: 6px; width: 3px; height: parent.height - 12px;
                                        border-radius: 1.5px;
                                        background: Palette.accent-background;
                                    }

                                    HorizontalLayout {
                                        padding-left: 12px;
                                        padding-right: 12px;
                                        Text {
                                            text: p.id;
                                            font-size: 12px;
                                            color: Palette.foreground;
                                            vertical-alignment: center;
                                            overflow: elide;
                                        }
                                    }
                                    item-touch := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => { root.select_preset(i); }
                                    }
                                }
                            }
                        }

                        HorizontalLayout {
                            spacing: 6px;
                            Button {
                                text: "New…";
                                clicked => { root.new_preset(); }
                            }
                            Button {
                                text: "Rename…";
                                enabled: root.selected_preset_index >= 0;
                                clicked => {
                                    root.rename_old_id = root.form.id;
                                    root.rename_new_id = root.form.id;
                                    root.show_rename_dialog = true;
                                }
                            }
                            Button {
                                text: "Delete";
                                enabled: root.selected_preset_index >= 0;
                                clicked => { root.delete_preset(root.form.id); }
                            }
                        }

                        Text {
                            text: root.presets_path;
                            font-size: 10px;
                            color: Palette.foreground.transparentize(0.5);
                            wrap: word-wrap;
                        }
                    }

                    // Right column: editor
                    ScrollView {
                        horizontal-stretch: 1;
                        VerticalLayout {
                            padding-left: 4px;
                            padding-right: 4px;
                            spacing: 14px;

                            Text {
                                text: root.selected_preset_index >= 0
                                    ? "Preset id: " + root.form.id
                                    : "Select a preset on the left, or click New…";
                                font-size: 14px;
                                font-weight: 600;
                                color: Palette.foreground;
                            }

                            SectionCard {
                                heading: "Model";
                                LabeledField {
                                    label: "Model file";
                                    hint: "Main model weights for this preset (--model / -m). Pick a .gguf from models\\.";
                                    ComboBox {
                                        model: root.model_labels;
                                        current-index <=> root.model_index;
                                        selected(value) => {
                                            let i = self.current-index;
                                            if (i >= 0 && i < root.model_values.length) {
                                                root.form.model = root.model_values[i];
                                            }
                                        }
                                    }
                                }
                                LabeledField {
                                    label: "MMProj";
                                    hint: "Multimodal projector (--mmproj) for vision models, so the server can read images. Blank for text-only models.";
                                    ComboBox {
                                        model: root.mmproj_labels;
                                        current-index <=> root.mmproj_index;
                                        selected(value) => {
                                            let i = self.current-index;
                                            if (i >= 0 && i < root.mmproj_values.length) {
                                                root.form.mmproj = root.mmproj_values[i];
                                            }
                                        }
                                    }
                                }
                            }

                            SectionCard {
                                heading: "Speculative decoding (MTP / DFlash)";
                                LabeledField {
                                    label: "Draft model";
                                    hint: "Optional speculator (feeds --model-draft). MTP heads (from mtps\\) set --spec-type draft-mtp; DFlash drafters (from dflashs\\) set draft-dflash. Picking one auto-pins the draft to the server GPU, or CPU if none. (none) = no speculation.";
                                    ComboBox {
                                        model: root.draft_labels;
                                        current-index <=> root.draft_index;
                                        selected(value) => {
                                            let i = self.current-index;
                                            if (i >= 0 && i < root.draft_values.length) {
                                                root.form.model_draft = root.draft_values[i];
                                                // Picking a draft model selects its speculator: MTP heads ->
                                                // draft-mtp, DFlash drafters -> draft-dflash, (none) -> none.
                                                root.form.spec_type = root.draft_specs[i];
                                                if (root.form.model_draft != "") {
                                                    // Run the draft on GPU by pinning it to one device (the multi-device
                                                    // auto split crashes gemma4 MTP heads). Reuse the server's GPU device
                                                    // if set; otherwise fall back to CPU, which always works.
                                                    if (root.form.n_gpu_layers_draft == "" && root.form.device_draft == "") {
                                                        if (root.server_device != "") {
                                                            root.form.device_draft = root.server_device;
                                                            root.form.n_gpu_layers_draft = "99";
                                                        } else {
                                                            root.form.n_gpu_layers_draft = "0";
                                                        }
                                                    }
                                                }
                                                // The draft-device dropdown was just changed programmatically.
                                                root.sync_device_dropdowns();
                                            }
                                        }
                                    }
                                }
                                LabeledField {
                                    label: "Spec type";
                                    hint: "Speculative decoding mode (--spec-type). Auto-set when you pick a draft model above: MTP heads → draft-mtp, DFlash drafters → draft-dflash. Override only if you know what you need.";
                                    ComboBox {
                                        model: ["none", "draft-mtp", "draft-dflash", "draft-simple", "ngram-mod"];
                                        current-value: root.form.spec_type == "" ? "none" : root.form.spec_type;
                                        selected(value) => { root.form.spec_type = value; }
                                    }
                                }
                                LabeledField {
                                    label: "Draft n-max";
                                    hint: "Max draft tokens proposed per step. DFlash clamps this to the GGUF's trained block_size-1 (e.g. 15). Blank = model default.";
                                    LineEdit {
                                        text: root.form.spec_draft_n_max;
                                        input-type: number;
                                        placeholder-text: "blank = default";
                                        edited(t) => { root.form.spec_draft_n_max = t; }
                                    }
                                }
                                LabeledField {
                                    label: "Draft GPU layers";
                                    hint: "99 = run the whole draft model on GPU (pin a device below — multi-GPU auto-split crashes MTP heads). 0 = CPU draft (always works). Blank = auto.";
                                    LineEdit {
                                        text: root.form.n_gpu_layers_draft;
                                        input-type: number;
                                        placeholder-text: "99 = GPU, 0 = CPU, blank = auto";
                                        edited(t) => { root.form.n_gpu_layers_draft = t; }
                                    }
                                }
                                LabeledField {
                                    label: "Draft device";
                                    hint: "GPU for the draft model (--device-draft). Pin to ONE device — multi-GPU auto-split crashes MTP heads. Blank = auto / same as model.";
                                    ComboBox {
                                        model: root.pdraft_labels;
                                        current-index <=> root.pdraft_index;
                                        selected(value) => {
                                            let i = self.current-index;
                                            if (i >= 0 && i < root.pdraft_values.length) {
                                                root.form.device_draft = root.pdraft_values[i];
                                            }
                                        }
                                    }
                                }
                            }

                            SectionCard {
                                heading: "Resource / context";
                                LabeledField {
                                    label: "Context size";
                                    hint: "Context window in tokens (--ctx-size). Bigger = longer history but more KV-cache VRAM; split across parallel slots.";
                                    LineEdit {
                                        text: "\{root.form.ctx_size}";
                                        input-type: number;
                                        edited(t) => { root.form.ctx_size = t.to-float(); }
                                    }
                                }
                                LabeledField {
                                    label: "GPU layers";
                                    hint: "--n-gpu-layers: model layers offloaded to GPU. 99 = all on GPU; lower keeps some on CPU to save VRAM.";
                                    LineEdit {
                                        text: "\{root.form.n_gpu_layers}";
                                        input-type: number;
                                        placeholder-text: "99 = all";
                                        edited(t) => { root.form.n_gpu_layers = t.to-float(); }
                                    }
                                }
                                LabeledField {
                                    label: "GPU device";
                                    hint: "GPU this model runs on (--device, e.g. CUDA0). Overrides the server default. Blank = use server default.";
                                    ComboBox {
                                        model: root.pdev_labels;
                                        current-index <=> root.pdev_index;
                                        selected(value) => {
                                            let i = self.current-index;
                                            if (i >= 0 && i < root.pdev_values.length) {
                                                root.form.device = root.pdev_values[i];
                                            }
                                        }
                                    }
                                }
                                LabeledField {
                                    label: "Parallel seqs";
                                    hint: "--parallel: concurrent request slots. Context is divided among them, so N=4 gives each slot ctx-size / 4 tokens.";
                                    LineEdit {
                                        text: "\{root.form.parallel}";
                                        input-type: number;
                                        edited(t) => { root.form.parallel = t.to-float(); }
                                    }
                                }
                                LabeledField {
                                    label: "Batch size";
                                    hint: "--batch-size: logical batch (tokens prefilled per step). Higher speeds prefill, uses more VRAM.";
                                    LineEdit {
                                        text: "\{root.form.batch_size}";
                                        input-type: number;
                                        edited(t) => { root.form.batch_size = t.to-float(); }
                                    }
                                }
                                LabeledField {
                                    label: "U-Batch size";
                                    hint: "--ubatch-size: physical micro-batch computed at once. Must be ≤ batch size.";
                                    LineEdit {
                                        text: "\{root.form.ubatch_size}";
                                        input-type: number;
                                        edited(t) => { root.form.ubatch_size = t.to-float(); }
                                    }
                                }
                            }

                            SectionCard {
                                heading: "KV cache";
                                LabeledField {
                                    label: "K-cache type";
                                    hint: "KV cache quantization. Lower = less VRAM but lower quality. Note: Qwen3-Coder needs q8_0 for reliable tool calling — q4_0 makes it drop the <tool_call> wrapper.";
                                    ComboBox {
                                        model: ["f32", "f16", "q8_0", "q5_0", "q4_0", "q4_1"];
                                        current-value: root.form.cache_type_k == "" ? "q8_0" : root.form.cache_type_k;
                                        selected(value) => { root.form.cache_type_k = value; }
                                    }
                                }
                                LabeledField {
                                    label: "V-cache type";
                                    hint: "KV cache quantization for V (--cache-type-v). Lower = less VRAM, lower quality; usually matched to K. Needs flash attention.";
                                    ComboBox {
                                        model: ["f32", "f16", "q8_0", "q5_0", "q4_0", "q4_1"];
                                        current-value: root.form.cache_type_v == "" ? "q8_0" : root.form.cache_type_v;
                                        selected(value) => { root.form.cache_type_v = value; }
                                    }
                                }
                                LabeledField {
                                    label: "Flash Attention";
                                    hint: "Enables the fused flash-attention kernel (-fa): faster prefill and lower KV memory. Recommended on; required for quantized KV cache to help on most backends.";
                                    CheckBox {
                                        text: "enable flash attention (-fa)";
                                        checked: root.form.flash_attn;
                                        toggled => { root.form.flash_attn = self.checked; }
                                    }
                                }
                                LabeledField {
                                    label: "Cache RAM (MiB)";
                                    hint: "--cache-ram: RAM limit (MiB) for the prompt cache (past-prompt KV kept for reuse). Blank = default; 0 disables.";
                                    LineEdit {
                                        text: "\{root.form.cache_ram}";
                                        input-type: number;
                                        placeholder-text: "8192";
                                        edited(t) => { root.form.cache_ram = t.to-float(); }
                                    }
                                }
                            }

                            SectionCard {
                                heading: "Chat / reasoning";
                                LabeledField {
                                    label: "Chat template";
                                    hint: "--jinja: use the model's embedded Jinja chat template instead of built-in heuristics. Recommended on for correct tool-call / role formatting.";
                                    CheckBox {
                                        text: "use embedded chat template (--jinja)";
                                        checked: root.form.jinja;
                                        toggled => { root.form.jinja = self.checked; }
                                    }
                                }
                                LabeledField {
                                    label: "Reasoning";
                                    hint: "auto: model decides (for Gemma auto≡on). on: force thinking. off: disable. Note reasoning=on can invalidate the KV cache mid-conversation; prefer auto.";
                                    // RadioGroup is driven from form.reasoning via each button's
                                    // `checked` binding; `selected` writes the pick back. Safe here
                                    // because the value is always exactly one of auto/on/off (never
                                    // empty/disabled), so the group never deselects-all.
                                    RadioGroup {
                                        orientation: horizontal;
                                        selected(value) => { root.form.reasoning = value; }
                                        RadioButton {
                                            text: "auto";
                                            checked: root.form.reasoning == "auto" || root.form.reasoning == "";
                                        }
                                        RadioButton {
                                            text: "on";
                                            checked: root.form.reasoning == "on";
                                        }
                                        RadioButton {
                                            text: "off";
                                            checked: root.form.reasoning == "off";
                                        }
                                    }
                                }
                                LabeledField {
                                    label: "Reason format";
                                    hint: "--reasoning-format: how thinking output is delivered. auto = let the template decide; deepseek = parse <think> blocks into a separate reasoning channel; none = inline.";
                                    RadioGroup {
                                        orientation: horizontal;
                                        selected(value) => { root.form.reasoning_format = value; }
                                        RadioButton {
                                            text: "auto";
                                            checked: root.form.reasoning_format == "auto" || root.form.reasoning_format == "";
                                        }
                                        RadioButton {
                                            text: "none";
                                            checked: root.form.reasoning_format == "none";
                                        }
                                        RadioButton {
                                            text: "deepseek";
                                            checked: root.form.reasoning_format == "deepseek";
                                        }
                                    }
                                }
                                LabeledField {
                                    label: "MoE CPU layers";
                                    hint: "Number of Mixture-of-Experts layers to keep on CPU (--n-cpu-moe) to save VRAM. Only applies to MoE models; N/A for dense models like Gemma. Blank = auto.";
                                    LineEdit {
                                        text: root.form.n_cpu_moe;
                                        input-type: number;
                                        placeholder-text: "blank = auto";
                                        edited(t) => { root.form.n_cpu_moe = t; }
                                    }
                                }
                            }

                            SectionCard {
                                heading: "Sampling overrides (blank = unset)";
                                LabeledField {
                                    label: "Temperature";
                                    hint: "--temp: sampling temperature. Lower = more deterministic, higher = more creative. Blank = default.";
                                    LineEdit {
                                        text: root.form.temp;
                                        placeholder-text: "default";
                                        edited(t) => { root.form.temp = t; }
                                    }
                                }
                                LabeledField {
                                    label: "Top-K";
                                    hint: "--top-k: keep only the K most-likely tokens before sampling. 0 / blank = disabled.";
                                    LineEdit {
                                        text: root.form.top_k;
                                        input-type: number;
                                        placeholder-text: "default";
                                        edited(t) => { root.form.top_k = t; }
                                    }
                                }
                                LabeledField {
                                    label: "Top-P";
                                    hint: "--top-p: nucleus sampling — smallest token set whose probabilities sum to P (e.g. 0.95). Blank = default.";
                                    LineEdit {
                                        text: root.form.top_p;
                                        placeholder-text: "default";
                                        edited(t) => { root.form.top_p = t; }
                                    }
                                }
                                LabeledField {
                                    label: "Min-P";
                                    hint: "--min-p: drop tokens below this fraction of the top token's probability. Blank = default.";
                                    LineEdit {
                                        text: root.form.min_p;
                                        placeholder-text: "default";
                                        edited(t) => { root.form.min_p = t; }
                                    }
                                }
                                LabeledField {
                                    label: "Repeat penalty";
                                    hint: "--repeat-penalty: >1 discourages repeating recent tokens (e.g. 1.1). Blank = default.";
                                    LineEdit {
                                        text: root.form.repeat_penalty;
                                        placeholder-text: "default";
                                        edited(t) => { root.form.repeat_penalty = t; }
                                    }
                                }
                                LabeledField {
                                    label: "Presence penalty";
                                    hint: "--presence-penalty: positive values discourage reusing any seen token, pushing new topics. Blank = default.";
                                    LineEdit {
                                        text: root.form.presence_penalty;
                                        placeholder-text: "default";
                                        edited(t) => { root.form.presence_penalty = t; }
                                    }
                                }
                            }

                            SectionCard {
                                heading: "Advanced";
                                LabeledField {
                                    label: "Chat kwargs";
                                    label_width: 130px;
                                    hint: "--chat-template-kwargs: JSON merged into the chat template, e.g. {\"enable_thinking\":true}. Advanced — leave blank unless the model documents kwargs.";
                                    LineEdit {
                                        text: root.form.chat_template_kwargs;
                                        placeholder-text: "e.g. {\"temperature\":0.7}";
                                        edited(t) => { root.form.chat_template_kwargs = t; }
                                    }
                                }
                            }

                            HorizontalLayout {
                                alignment: end;
                                spacing: 8px;
                                Button {
                                    text: "Revert";
                                    enabled: root.selected_preset_index >= 0 && root.preset_dirty;
                                    clicked => { root.revert_preset(); }
                                }
                                Button {
                                    text: "Save preset";
                                    primary: true;
                                    enabled: root.selected_preset_index >= 0 && root.form.id != "" && root.preset_dirty;
                                    clicked => { root.save_preset(); }
                                }
                            }
                        }
                    }
                }

                // ─────────────── Page 2: Integrations ───────────────
                if root.current_tab == 2 : ScrollView {
                    VerticalLayout {
                        padding: 24px;
                        spacing: 16px;
                        alignment: start;

                        Text {
                            text: "Integrations";
                            font-size: 22px;
                            font-weight: 600;
                            color: Palette.foreground;
                        }
                        Text {
                            text: "Expose presets as models in your AI coding tools. OpenCode is configured directly; Claude Code needs environment variables.";
                            color: Palette.foreground.transparentize(0.4);
                            font-size: 12px;
                            wrap: word-wrap;
                        }

                        SectionCard {
                            heading: "Provider";
                            LabeledField {
                                label: "Status";
                                Text {
                                    text: root.integration_provider_active
                                        ? "llama-server provider active in opencode.json"
                                        : "No llama-server provider in opencode.json";
                                    color: root.integration_provider_active ? #2e7d32 : Palette.foreground.transparentize(0.45);
                                    font-size: 13px;
                                    vertical-alignment: center;
                                }
                            }
                            LabeledField {
                                label: "baseURL";
                                hint: "OpenAI-compatible endpoint exposed by llama-server (host:port + /v1). Point OpenCode / Claude Code at this URL.";
                                LineEdit {
                                    text: root.integration_base_url;
                                    read-only: true;
                                    horizontal-stretch: 1;
                                }
                            }
                        }

                        SectionCard {
                            heading: "Models (toggle presets to expose)";
                            content_padding: 8px;

                            if root.integration_models.length == 0 : Text {
                                text: "No presets found. Create presets under the Models tab first.";
                                font-size: 12px;
                                color: Palette.foreground.transparentize(0.45);
                                wrap: word-wrap;
                            }

                            for item[i] in root.integration_models : Rectangle {
                                height: 36px;
                                background: Math.mod(i, 2) == 0 ? transparent : Palette.alternate-background.transparentize(0.3);

                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 12px;
                                    spacing: 8px;
                                    CheckBox {
                                        text: "";
                                        checked: item.enabled;
                                        toggled => { root.toggle_integration_model(i); }
                                    }
                                    Text {
                                        text: item.id;
                                        font-size: 13px;
                                        font-weight: 600;
                                        color: Palette.foreground;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: item.label;
                                        font-size: 11px;
                                        color: Palette.foreground.transparentize(0.4);
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                }
                            }
                        }

                        SectionCard {
                            heading: "Claude Code";
                            content_padding: 12px;
                            Text {
                                text: "Claude Code uses environment variables to connect to a custom endpoint. Copy the snippet below and run it in PowerShell before launching Claude Code, or add it to your PROFILE.";
                                wrap: word-wrap;
                                font-size: 12px;
                                color: Palette.foreground.transparentize(0.4);
                            }
                            LineEdit {
                                text: root.integration_claude_env;
                                read-only: true;
                                font-size: 11px;
                                horizontal-stretch: 1;
                            }
                        }

                        HorizontalLayout {
                            alignment: end;
                            spacing: 8px;
                            Button {
                                text: "Revert";
                                clicked => { root.revert_integrations(); }
                            }
                            Button {
                                text: "Save to opencode.json";
                                primary: true;
                                clicked => { root.save_integrations(); }
                            }
                        }
                    }
                }

                } // /VerticalLayout (content swap)
            }
        }

        // ─── Footer status bar ──────────────────────────────────────
        Rectangle {
            height: 32px;
            horizontal-stretch: 1;
            background: Palette.alternate-background;
            Rectangle {
                y: 0;
                height: 1px;
                horizontal-stretch: 1;
                background: Palette.border;
            }
            // ─── Messages (left) ──────────────────────────────────
            if root.status_text != "" : Text {
                x: 16px;
                y: 0;
                height: 100%;
                text: root.status_text;
                color: root.status_is_error ? #c62828 : Palette.foreground;
                font-size: 12px;
                vertical-alignment: center;
            }

            // ─── Server status (right) ────────────────────────────
            Text {
                x: parent.width - 140px;
                y: 0;
                height: 100%;
                width: 108px;
                text: root.server_status_is_error ? "Error"
                    : (root.server_running ? "Running" : "Stopped");
                font-size: 12px;
                vertical-alignment: center;
                horizontal-alignment: right;
                color: Palette.foreground.transparentize(0.45);
            }
            Rectangle {
                x: parent.width - 24px;
                y: 12px;
                width: 8px;
                height: 8px;
                border-radius: 4px;
                background: root.server_status_is_error ? #c62828
                    : (root.server_running ? #2e7d32 : #666666);
            }
        }

    } // /main VerticalLayout
    } // /shortcuts FocusScope
} // End of AppWindow

// ── System tray ──────────────────────────────────────────────────────
// Separate root component (instantiated alongside AppWindow in gui.rs). Left-click
// reopens the window; right-click (Windows) opens the menu. `server_running` is kept
// in sync from Rust so the hover tooltip reflects live status.
export component AppTray inherits SystemTrayIcon {
    in property <bool> server_running;
    // Swap to the green-dotted icon while the server is up (both PNGs are
    // generated by build.rs). The icon property is change-tracked, so this
    // updates the tray live as the status flips.
    icon: root.server_running ? @image-url("llama-on.png") : @image-url("llama.png");
    tooltip: root.server_running ? "llama.cpp — server running" : "llama.cpp — server stopped";
    callback open_window();
    callback start_server();
    callback stop_server();
    callback quit_app();
    clicked => { root.open_window(); }
    Menu {
        MenuItem { title: "Open configurator"; activated => { root.open_window(); } }
        MenuSeparator { }
        // Start only when stopped; Stop only when running. The menu tree is
        // reactive, so it rebuilds when server_running changes.
        if !root.server_running : MenuItem { title: "Start server"; activated => { root.start_server(); } }
        if root.server_running : MenuItem { title: "Stop server"; activated => { root.stop_server(); } }
        MenuSeparator { }
        MenuItem { title: "Quit"; activated => { root.quit_app(); } }
    }
}
