// Shared Slint structs used across the configurator UI.

export struct PresetSummary {
    id: string,
    // Index into the full (unfiltered) presets vector on the Rust side. The list
    // model only holds rows that pass the filter, so the `for` index is NOT a
    // stable handle — `orig_index` is what select_preset()/highlighting use.
    orig_index: int,
}

// Adding a field? This struct is step 5 of the 7-step fan-out documented at the
// top of src/presets.rs (struct + Default + from_keys + render_section here in
// Rust, PresetForm + widget in Slint, both form.rs conversions).
export struct PresetForm {
    id: string,
    model: string,
    mmproj: string,
    // --mmproj-offload: run the image encoder on GPU (llama.cpp's default) or
    // keep it on CPU. Plain bool (CheckBox, two-way <=>), same shape as jinja.
    mmproj_offload: bool,
    model_draft: string,
    spec_type: string,
    spec_draft_n_max: string,
    spec_draft_n_max_default: bool,
    n_gpu_layers_draft: int,
    n_gpu_layers_draft_auto: bool,
    device_draft: string,
    device: string,
    split_mode: string,
    tensor_split: string,
    // --override-tensor: the `<regex>=<device>,…` rule list, written by the
    // tensor-placement table (TensorOverrideTable), never typed — llama.cpp
    // splits the value on `,` and at the first `=` before it parses anything, so
    // a free-text field would let an unescapable separator through. Same
    // table-not-a-field reasoning as `device`/`tensor_split` above; the rules
    // live in src/tensor_override.rs.
    override_tensor: string,
    // Numerics ride as STRINGS, integers included: every one of them is a
    // `DefaultLineEdit` (`value <=>`), because the SpinBox they used to sit in
    // edits itself on a stray mouse-wheel over the page — see the component's
    // header. The text is what the user typed; Rust re-parses it (`ini::parse_int`)
    // and an unparseable field reads as unset, exactly like the float knobs.
    // The `*_default` bool carries the "omit the flag" state (checkbox checked =
    // let llama.cpp pick its own default); the string is populated even then, so
    // the disabled field shows a hint (form.rs's HINT_*) of what unticking gives.
    // The three LAYER counts below are the exception — they stay `int`, because
    // they ride a Slider (AutoSlider), which has no scroll handler to abuse.
    ctx_size: string,
    ctx_size_default: bool,
    n_gpu_layers: int,
    n_gpu_layers_auto: bool,
    parallel: string,
    parallel_default: bool,
    batch_size: string,
    batch_size_default: bool,
    ubatch_size: string,
    ubatch_size_default: bool,
    // --cache-type-k/-v: an EnumComboBox over Options.cache_types, whose FIRST
    // entry is "default" — the spelling this string carries for the empty INI
    // value (omit the flag). Same empty↔"default" mapping as `split_mode` above.
    cache_type_k: string,
    cache_type_v: string,
    // --flash-attn, a TRI-state carried as a string like `reasoning_preserve`
    // below: "default" (omit the flag — llama.cpp's own default is `auto`), "on",
    // "off". Not a bool: the flag takes [on|off|auto], so a checkbox could only
    // ever reach two of its three states, and the unreachable one is the default.
    flash_attn: string,
    // --cache-ram is the one integer field that must accept a leading `-` (its
    // `-1` = no limit), so its widget takes `input_type: decimal` while the other
    // integers are digits-only `number`. See DefaultLineEdit.
    cache_ram: string,
    cache_ram_default: bool,
    jinja: bool,
    reasoning: string,
    reasoning_format: string,
    // --reasoning-preserve, a TRI-state carried as a string: "default" (omit the
    // flag — the template's own behaviour), "on", "off". Not a bool: "off"
    // (--no-reasoning-preserve) and "default" are different instructions.
    reasoning_preserve: string,
    n_cpu_moe: int,
    n_cpu_moe_auto: bool,
    // Sampling knobs, each paired with a `*_default` bool (checkbox omits the
    // flag — same shape as the integer fields above). Top-K is integer-valued, so
    // its field is digits-only (`input_type: number`); the rest are floats
    // (`decimal`). All of them are `DefaultLineEdit`s over a string.
    top_k: string,
    top_k_default: bool,
    temp: string,
    temp_default: bool,
    top_p: string,
    top_p_default: bool,
    min_p: string,
    min_p_default: bool,
    repeat_penalty: string,
    repeat_penalty_default: bool,
    presence_penalty: string,
    presence_penalty_default: bool,
    chat_template_kwargs: string,
}

// The server tab's edit form, the server-side mirror of PresetForm: all of
// server.ini's editable fields in one struct so the Server page binds two-way to
// `AppState.server_form.<field>`, dirty-tracking is a single struct compare
// (`server_form != server_form_base`). Adding a server field follows the
// checklist at the top of src/server_cfg.rs (this struct + server_page.slint +
// server_cfg.rs + both conversions in src/server_form.rs + 3 spots in cli.rs +
// runstate::server_args) — never the GUI wiring. Numerics ride as `string` paired
// with a `*_default` bool (a DefaultLineEdit — checkbox omits the flag), for the
// same reason PresetForm's do: their old SpinBox edited itself on a stray scroll.
// The CPU-thread counts instead ride as slider `int`s paired with an `_auto` flag
// (auto = omit the flag, let llama.cpp pick), the same shape as PresetForm's
// layer sliders — a Slider has no scroll handler, so it keeps its int.
export struct ServerForm {
    port: string,
    port_default: bool,
    hostname: string,
    mlock: bool,
    // --no-mmap: read the weights into RAM instead of mmapping the GGUF. Same
    // plain-bool shape as `mlock`; checked = pass the flag (framework default: off).
    no_mmap: bool,
    threads: int,
    threads_auto: bool,
    cache_reuse: string,
    cache_reuse_default: bool,
    threads_batch: int,
    threads_batch_auto: bool,
    models_max: string,
    models_max_default: bool,
    models_dir: string,
    // `device` + `tensor_split` are written by the GPU distribution table
    // (GpuSplitTable), not typed: --tensor-split is positional over --device, so
    // the two only make sense edited together. `mmproj_device` is separate on
    // purpose — the image encoder ignores --device (see server_cfg.rs).
    device: string,
    split_mode: string,
    tensor_split: string,
    // --override-tensor, the server-wide twin of PresetForm's field above (same
    // TensorOverrideTable, same `<regex>=<device>,…` grammar). Set here it
    // REPLACES every preset's rules rather than adding to them: the router merges
    // its own CLI args into each preset as a key→value map, so only one
    // --override-tensor ever reaches a child (verified — see server_cfg.rs).
    override_tensor: string,
    mmproj_device: string,
    // Plain bool toggles (CheckBox, two-way <=>), the same shape as `mlock`:
    // webui_mcp_proxy enables the web UI's MCP proxy (--webui-mcp-proxy); fit is
    // llama.cpp's -fit on|off VRAM auto-fitting (checked = on); prefill_assistant
    // continues a TRAILING assistant message instead of answering it
    // (--no-prefill-assistant turns it off — checked = llama.cpp's own default).
    webui_mcp_proxy: bool,
    fit: bool,
    prefill_assistant: bool,
    // Log verbosity threshold (-lv), carried as the DROPDOWN LABEL — "DEBUG:5",
    // "TRACE:4", … — not as the bare number. llama.cpp defines exactly six levels
    // and nothing else is meaningful (`common/arg.cpp`), so the widget is an
    // EnumComboBox over `Options.log_levels` and the label is what round-trips;
    // `server_form::log_level_label` / `parse_log_level` map it to the int, and the
    // Rust list is asserted against the Slint one in the e2e (they must not drift).
    log_verbosity: string,
    // Integration base URL (server.ini OpencodeBaseUrl). When base_url_default is
    // true, the field shows the auto-derived URL and nothing is written to server.ini.
    opencode_base_url: string,
    base_url_default: bool,
    // API key for the integration provider (server.ini OpencodeApiKey). When
    // api_key_nokey is true, the field is disabled and no key is used.
    opencode_api_key: string,
    api_key_nokey: bool,
}

export struct IntegrationModel {
    id: string,
    label: string,
    enabled: bool,
}

// One row of the GPU distribution table (GpuSplitTable in components.slint), the
// widget behind the `device` + `tensor_split` string pair on BOTH forms. Rows are
// built entirely in Rust (src/gpu_split.rs — selected devices first, in split
// order, since that order IS the --tensor-split index) and are read-only to
// Slint: the delegates report edits through the page's callbacks, which rewrite
// the two form strings and rebuild the whole model. `share` and `vram` arrive
// pre-formatted so no percentage math lives in the .slint.
export struct GpuRow {
    id: string,
    name: string,
    vram: string,
    // False for a selected device the --list-devices probe doesn't know (stale
    // config, another machine's GPU, or simply the async probe hasn't landed).
    // The row is kept anyway so saving can't silently drop it.
    detected: bool,
    enabled: bool,
    weight: int,
    share: string,
}

// One rule of the tensor-placement table (TensorOverrideTable in
// components.slint), the widget behind the preset's `override_tensor` string.
// Same shape as GpuRow: built entirely in Rust (src/tensor_override.rs) and
// read-only to Slint — the delegates report edits through the page's callbacks,
// which rewrite the one form string and rebuild the whole model. Rows are
// addressed by INDEX (a pattern may legitimately repeat, so there is no id).
export struct TensorOverrideRow {
    // The rule's regex, matched against tensor names with regex_search.
    pattern: string,
    // Which entry of AppState.tensor_kind_labels this pattern is: a canned one,
    // or the last index = "Custom regex…" (`custom`), which is the only kind
    // that shows the pattern's text field.
    kind_index: int,
    custom: bool,
    // The target buffer type — a device id, or CPU — and its position in the
    // shared AppState.tensor_dev_values model. -1 when the rule names none.
    device: string,
    device_index: int,
    // False for a device the --list-devices probe doesn't know; the rule is kept
    // (and offered as a "(custom)" dropdown entry) so a save can't drop it.
    detected: bool,
    // This row's own complaint, or "" when it is fine.
    problem: string,
}
