// Shared Slint structs used across the configurator UI.

export struct PresetSummary {
    id: string,
    // Index into the full (unfiltered) presets vector on the Rust side. The list
    // model only holds rows that pass the filter, so the `for` index is NOT a
    // stable handle — `orig_index` is what select_preset()/highlighting use.
    orig_index: int,
}

// Adding a field? This struct is step 5 of the 7-step fan-out documented at the
// top of src/presets.rs (struct + Default + from_keys + render_section here in
// Rust, PresetForm + widget in Slint, both form.rs conversions).
export struct PresetForm {
    id: string,
    model: string,
    mmproj: string,
    model_draft: string,
    spec_type: string,
    spec_draft_n_max: int,
    spec_draft_n_max_default: bool,
    n_gpu_layers_draft: int,
    n_gpu_layers_draft_auto: bool,
    device_draft: string,
    device: string,
    split_mode: string,
    tensor_split: string,
    // Integer numerics: two-way-bound to a DefaultSpinBox `value` (int). The
    // `*_default` bool carries the "omit the flag" state (checkbox checked =
    // let llama.cpp pick its own default); the int is always populated so the
    // disabled SpinBox shows a sensible hint (the schema default) when the
    // checkbox is on — see preset_to_form in src/form.rs.
    ctx_size: int,
    ctx_size_default: bool,
    n_gpu_layers: int,
    n_gpu_layers_auto: bool,
    parallel: int,
    parallel_default: bool,
    batch_size: int,
    batch_size_default: bool,
    ubatch_size: int,
    ubatch_size_default: bool,
    cache_type_k: string,
    cache_type_v: string,
    flash_attn: bool,
    cache_ram: int,
    cache_ram_default: bool,
    jinja: bool,
    reasoning: string,
    reasoning_format: string,
    n_cpu_moe: int,
    n_cpu_moe_auto: bool,
    // Sampling knobs, each paired with a `*_default` bool (checkbox omits the
    // flag — same shape as the integer fields above). Top-K is integer-valued
    // (a DefaultSpinBox `value`, int); the float knobs (temp/top-p/min-p/
    // penalties) ride as `string` (a DefaultLineEdit `text <=>`) since SpinBox
    // is int-only.
    top_k: int,
    top_k_default: bool,
    temp: string,
    temp_default: bool,
    top_p: string,
    top_p_default: bool,
    min_p: string,
    min_p_default: bool,
    repeat_penalty: string,
    repeat_penalty_default: bool,
    presence_penalty: string,
    presence_penalty_default: bool,
    chat_template_kwargs: string,
}

// The server tab's edit form, the server-side mirror of PresetForm: all of
// server.ini's editable fields in one struct so the Server page binds two-way to
// `AppState.server_form.<field>`, dirty-tracking is a single struct compare
// (`server_form != server_form_base`). Adding a server field follows the
// checklist at the top of src/server_cfg.rs (this struct + server_page.slint +
// server_cfg.rs + both conversions in src/server_form.rs + 3 spots in cli.rs +
// runstate::server_args) — never the GUI wiring. Numerics ride as `int` paired
// with a `*_default` bool (a DefaultSpinBox — checkbox omits the flag); the
// CPU-thread counts instead ride as slider `int`s paired with an `_auto` flag
// (auto = omit the flag, let llama.cpp pick), the same shape as PresetForm's
// layer sliders.
export struct ServerForm {
    port: int,
    port_default: bool,
    hostname: string,
    mlock: bool,
    threads: int,
    threads_auto: bool,
    cache_reuse: int,
    cache_reuse_default: bool,
    threads_batch: int,
    threads_batch_auto: bool,
    models_max: int,
    models_max_default: bool,
    models_dir: string,
    device: string,
    split_mode: string,
    tensor_split: string,
}

export struct IntegrationModel {
    id: string,
    label: string,
    enabled: bool,
}
