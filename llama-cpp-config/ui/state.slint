// Shared application state for the configurator.
//
// Every property and callback that Rust drives — plus anything more than one
// component reads — lives here, in one exported global, so each datum is
// declared ONCE instead of three times (AppWindow field → forwarding binding →
// page field). The tab pages are conditionally instantiated, so Rust cannot
// reach a property declared on a page: a Rust-driven datum belongs here even
// when a single page reads it. Rust drives the global via
// `app.global::<AppState>()`; the pages read/write `AppState.<name>` directly.
//
// The tray (`AppTray` in app.slint) is a separate root and does NOT use this
// global — it keeps its own pushed-in state.

import { PresetSummary, PresetForm, ServerForm, IntegrationModel, GpuRow, TensorOverrideRow } from "types.slint";
import { Options } from "components.slint";

export global AppState {
    // Crate version (CARGO_PKG_VERSION), pushed in from Rust at startup so the
    // title bar always reflects the built version.
    in-out property <string> app_version;

    // ── Navigation ───────────────────────────────────────────────────
    // 0 = Server, 1 = Models, 2 = Integrations.
    in-out property <int> current_tab: 0;

    // ── Live status ──────────────────────────────────────────────────
    in-out property <bool> server_running: false;
    // Transitional flag: Stop has been triggered but the process is still
    // running (a forced kill lingers a moment while the GPU context unwinds).
    // Held true by Rust until `tasklist` confirms the process is gone.
    in-out property <bool> server_stopping: false;
    // Transitional flag: Start has been triggered but the launch (which opens
    // with a tasklist probe) hasn't completed — held true by Rust while the
    // start runs off the UI thread, mirroring server_stopping.
    in-out property <bool> server_starting: false;
    in-out property <bool> server_status_is_error: false;
    in-out property <string> server_version: "";
    in-out property <string> server_command_line: "";
    // Client URL of the SAVED server.ini, derived by Rust alongside the
    // command line (gui::refresh_server_snapshot): saved port + client_host,
    // which maps a 0.0.0.0 bind to localhost (a listen address is not a
    // connectable one).
    in-out property <string> chat_url: "";
    // Client URL snapshotted when the GUI launched llama-server (empty while
    // stopped, or when the server was started outside the GUI). The RUNNING
    // process listens on what it was launched with — saving a new port only
    // changes the file — so the Open-chat button prefers this over chat_url.
    in-out property <string> launched_url: "";
    out property <string> open_chat_url: server_running && launched_url != "" ? launched_url : chat_url;

    // ── Server tab state ─────────────────────────────────────────────
    // All editable server.ini fields live in one struct (ServerForm), like the
    // preset side's `form`. Rust drives it via config_to_form / form_to_config
    // (src/server_form.rs); `server_form_base` is the loaded/saved baseline and
    // dirty-tracking is a single struct compare. The bind/device dropdowns below
    // are option lists (not form values), so they stay separate.
    // No Slint-side initializer: Rust seeds both structs from disk before the
    // event loop starts (gui::run() → load_server_into_ui), and the display
    // defaults have ONE owner — server_form::config_to_form.
    in-out property <ServerForm> server_form;
    in-out property <ServerForm> server_form_base;
    out property <bool> server_dirty: server_form != server_form_base;
    // Save gating shared by the Server tab's Save button and the Ctrl+S
    // shortcut (app.slint) — single source so the two can't drift.
    out property <bool> can_save_server: server_dirty;

    // Logical-processor count (std::thread::available_parallelism), pushed from
    // Rust at startup — the upper bound for the CPU-threads / batch-threads
    // sliders. A generous fallback keeps the sliders usable if the probe fails.
    in-out property <int> cpu_threads_max: 32;

    // "Bind to" (hostname) dropdown options, derived from the local interfaces.
    in-out property <[string]> bind_labels;
    in-out property <[string]> bind_values;
    in-out property <int> bind_index: 0;

    // Server-wide GPU distribution table (GpuSplitTable). Rows come from the
    // async `--list-devices` probe crossed with `server_form.device` /
    // `.tensor_split` — Rust owns both the row model and the strings it renders
    // back into (src/gpu_split.rs). The per-preset twin lives under "Models tab
    // state" below; the raw device list stays Rust-only (`devices::probed()`).
    in-out property <[GpuRow]> server_gpu_rows;
    // The llama-server flags this selection produces, shown under the table.
    in-out property <string> server_gpu_summary;
    // How many devices are checked. Drives the split-mode combo (one device has
    // nothing to split) and the weight column (so does zero).
    in-out property <int> server_gpu_selected: 0;
    // Sum of the checked devices' weights. 0 = Auto (blank --tensor-split →
    // llama.cpp splits by free VRAM); any positive value means explicit weights,
    // and is the denominator behind the table's Share column.
    in-out property <int> server_gpu_total: 0;

    // Server-wide tensor-placement table (TensorOverrideTable) — the twin of the
    // per-preset one below, over `server_form.override_tensor`.
    in-out property <[TensorOverrideRow]> server_tensor_rows;
    in-out property <string> server_tensor_summary;
    in-out property <string> server_tensor_warning;
    in-out property <[string]> server_tensor_dev_labels;
    in-out property <[string]> server_tensor_dev_values;

    // Vision-encoder (mmproj) device dropdown triple. Its own list because the
    // CLIP context ignores --device entirely: llama.cpp grabs the first GPU
    // backend it finds unless MTMD_BACKEND_DEVICE names one (see runstate::start).
    in-out property <[string]> mmproj_dev_labels;
    in-out property <[string]> mmproj_dev_values;
    in-out property <int> mmproj_dev_index: 0;

    // ── Models tab state ─────────────────────────────────────────────
    in-out property <[PresetSummary]> presets;
    in-out property <int> selected_preset_index: -1;
    in-out property <PresetForm> form;
    // Baseline snapshot of the loaded preset (set by Rust whenever the form is
    // (re)loaded or saved). Struct inequality drives Save/Revert enabled.
    in-out property <PresetForm> form_base;
    out property <bool> preset_dirty: form != form_base;
    // Save gating shared by the Models tab's Save button and the Ctrl+S
    // shortcut (app.slint) — single source so the two can't drift.
    out property <bool> can_save_preset: selected_preset_index >= 0 && form.id != "" && preset_dirty;
    in-out property <string> presets_path: "";
    in-out property <string> presets_filter: "";

    // Per-preset GPU distribution table — the twin of the server-wide one above,
    // over `form.device` / `form.tensor_split`. Overridden at launch by a
    // server-wide selection (llama-server's router copies its OWN CLI args over
    // every preset key), which is what `gpu_override_warning` says out loud.
    in-out property <[GpuRow]> preset_gpu_rows;
    in-out property <string> preset_gpu_summary;
    in-out property <int> preset_gpu_selected: 0;
    in-out property <int> preset_gpu_total: 0;
    out property <string> gpu_override_warning: server_form.device == "" ? ""
        : "The Server tab pins GPUs (" + server_form.device + "). llama-server passes that on its own command line, which overrides every preset's selection — this table won't apply until the server-wide one is cleared.";

    // Per-preset tensor-placement table (TensorOverrideTable), over the single
    // `form.override_tensor` string. Rows and BOTH dropdown models are built in
    // Rust (src/tensor_override.rs) and are read-only to Slint; every edit is a
    // whole-string rewrite. Rules are addressed by ROW INDEX, not by an id — the
    // same pattern may legitimately appear twice (two devices, two halves of a
    // model), unlike the GPU table's unique device ids.
    in-out property <[TensorOverrideRow]> preset_tensor_rows;
    in-out property <string> preset_tensor_summary;
    // The exact twin of `gpu_override_warning`: a server-wide value shadows this
    // table. And it shadows it WHOLESALE — `-ot` is a vector inside llama.cpp, so
    // "the two lists get concatenated" is the natural guess and it is wrong: the
    // router merges its own CLI args into every preset as a key→value map, so the
    // server's `--override-tensor` overwrites the preset's key and only one flag
    // ever reaches the child. Verified against b9976; see server_cfg.rs.
    out property <string> tensor_override_warning: server_form.override_tensor == "" ? ""
        : "The Server tab sets a tensor placement (" + server_form.override_tensor + "). llama-server passes that on its own command line, which REPLACES every preset's rules — these ones won't apply at all until the server-wide table is cleared.";
    // Non-empty when the value is one llama.cpp would refuse (a rule with no
    // device). Only a hand-edited presets.ini reaches it — the table sanitizes
    // everything it writes — but that value would fail the model's LOAD, so it
    // is worth saying out loud rather than at the next launch.
    in-out property <string> preset_tensor_warning;
    // The option models behind every row's two dropdowns. The KIND list is shared
    // by both tables (canned patterns; last entry = "Custom regex…", the only one
    // that reveals the pattern's text field). The DEVICE list is NOT: it is the
    // probed devices INCLUDING the CPU (a legal -ot target, unlike in the GPU
    // table above) PLUS a `(custom)` entry per device id the probe doesn't know,
    // which is a property of that table's own rules — so each scope gets its own
    // model, or the two would alias each other's row indices (see gui.rs).
    in-out property <[string]> tensor_kind_labels;
    in-out property <[string]> tensor_kind_values;
    in-out property <[string]> preset_tensor_dev_labels;
    in-out property <[string]> preset_tensor_dev_values;

    // Draft-model GPU-device dropdown triple, fed from the same
    // `devices::probed()` cache as the tables above. Still a dropdown, not a
    // table: --device-draft takes ONE device (a draft is never split).
    in-out property <[string]> preset_draft_dev_labels;
    in-out property <[string]> preset_draft_dev_values;
    in-out property <int> preset_draft_dev_index: 0;

    // File-field dropdowns for model and mmproj
    in-out property <[string]> model_labels;
    in-out property <[string]> model_values;
    in-out property <int> model_index: -1;
    in-out property <[string]> mmproj_labels;
    in-out property <[string]> mmproj_values;
    in-out property <int> mmproj_index: -1;
    // Unified draft-model picker (MTP heads from mtps\ + DFlash drafters from
    // dflashs\). Only labels + index live here; the per-row (--model-draft,
    // --spec-type) pairs are Rust-only (`State.draft_rows` in gui.rs), read by
    // the draft_picked handler.
    in-out property <[string]> draft_labels;
    in-out property <int> draft_index: -1;

    // Read-only "Model info" box, filled by Rust (model_changed) from the
    // selected model's GGUF header. `model_info_ready` gates between the info
    // rows and a muted placeholder/error note (`model_info_note`).
    in-out property <bool> model_info_ready: false;
    in-out property <string> model_info_note;
    in-out property <string> model_info_kind;
    // MoE-only: how many layers hold experts + the --n-cpu-moe range. Hidden for
    // dense models (`model_info_has_moe`).
    in-out property <bool> model_info_has_moe: false;
    in-out property <string> model_info_moe;
    in-out property <string> model_info_arch_quant;
    // token_embd's OWN quant + size — not implied by the file's name or by
    // `model_info_arch_quant`: Unsloth's Q6_K_XL keeps the embedding table at
    // Q8_0 while its Q4_K_XL/Q5_K_XL drop it to a K-quant, and only the former
    // can be pinned to a GPU (CUDA/ROCm implement get_rows for no K-quant).
    // `model_info_embd_warning` is non-empty ONLY when the type is known AND
    // unpinnable — it is what the Tensor-placement table shows when a rule
    // pins the table anyway. Empty for an unreadable GGUF, so a failed metadata
    // read never masquerades as a problem.
    in-out property <string> model_info_embd;
    in-out property <string> model_info_embd_warning;
    in-out property <string> model_info_layers_ctx;
    in-out property <string> model_info_attn;
    in-out property <string> model_info_draft;
    // Chat template detection (read from GGUF `tokenizer.chat_template`).
    // `model_info_chat_template` is the short status text — rendered in a
    // LabeledField (not an InfoRow) so a Preview button can sit beside it —
    // ("Jinja (embedded)" / "embedded (non-Jinja)" / "none");
    // `chat_template_preview` holds the raw template text for the Preview
    // modal, and is empty when no template is embedded — which also gates the
    // Preview button (no point previewing an absent template).
    in-out property <string> model_info_chat_template: "none";
    in-out property <string> chat_template_preview: "";
    // Reasoning support, read off that same template's SOURCE (no Jinja engine
    // here — see gguf.rs `Thinking`). `model_info_thinking` says whether the model
    // thinks and whether --reasoning can switch it; `model_info_past_thinking`
    // says whether --reasoning-preserve is a LEVER at all — i.e. whether the
    // template names one of the three variables that flag sets. A `no` there is
    // the useful half: it means the flag changes nothing on this model, which the
    // llama-server log cannot tell you (its probe reports "supported" for a
    // template that preserves unconditionally too).
    in-out property <string> model_info_thinking: "unknown";
    in-out property <string> model_info_past_thinking: "unknown";
    // Optional rows, shown only when a mmproj / draft file is selected.
    in-out property <bool> model_info_has_mmproj: false;
    in-out property <string> model_info_mmproj;
    in-out property <bool> model_info_has_draft_file: false;
    in-out property <string> model_info_draft_file;
    // True when the main model embeds MTP/nextn heads (`<arch>.nextn_predict_layers` > 0):
    // speculative decoding is possible even before an external draft file is picked.
    in-out property <bool> model_info_embeds_mtp: false;
    // Layer counts (block_count) of the selected model and draft, driving the
    // GPU-layers / MoE-CPU-layers / draft-GPU-layers slider maxima. For the
    // MODEL sliders 0 = unknown (metadata unavailable) and gpu_layers_max
    // falls back to a 0..Options.all_layers range; the draft slider needs no
    // fallback — models_page only shows it when draft_n_layer > 0 (a 0-layer
    // MTP head gets the CPU/GPU switch instead).
    in-out property <int> model_info_n_layer: 0;
    in-out property <int> model_info_draft_n_layer: 0;
    out property <int> gpu_layers_max: model_info_n_layer > 0 ? model_info_n_layer : Options.all_layers;
    out property <int> draft_layers_max: model_info_draft_n_layer;
    // Speculative-decoding controls are active when a draft model is selected OR
    // the main model embeds MTP heads — otherwise there is nothing to draft with.
    out property <bool> draft_active: form.model_draft != "" || model_info_embeds_mtp;
    // …but the draft PLACEMENT controls (--device-draft, --n-gpu-layers-draft)
    // need a separate draft FILE, not just a draft. llama.cpp applies both only
    // inside `if (has_dft())`, i.e. when a --model-draft path was given; with
    // embedded MTP heads it builds the draft context against the target model
    // itself ("MTP draft context lives on the target model" — server-context.cpp),
    // so the draft runs on the MODEL's device and both flags are silently ignored.
    // Enabling them anyway is how a draft ends up "pinned" to a GPU that then sits
    // idle. `embedded_mtp_note` explains that where the controls are.
    out property <bool> draft_file_active: form.model_draft != "";
    out property <bool> embedded_mtp_note: draft_active && !draft_file_active;

    // ── New-preset dialog state ─────────────────────────────────────
    in-out property <bool> show_new_kind_picker: false;
    in-out property <string> new_dialog_source_id: "";
    in-out property <[string]> dialog_model_labels;
    in-out property <int> dialog_model_index: -1;
    in-out property <string> dialog_filter: "";

    // ── Rename-preset dialog state ──────────────────────────────────
    in-out property <bool> show_rename_dialog: false;
    in-out property <string> rename_old_id: "";
    in-out property <string> rename_new_id: "";

    // ── Discard-confirm dialog state ─────────────────────────────────
    // Shown by Rust (gui::confirm_discard_then) when a navigation action —
    // preset switch, Refresh/reload_all, New…/Clone…/Rename… — would replace
    // a dirty form. The pending action is stashed Rust-side (gui::State) and
    // runs only on confirm; cancel drops it and keeps the edits.
    in-out property <bool> show_discard_dialog: false;

    // ── Delete-confirm dialog state ──────────────────────────────────
    // Purely Slint-side: the Models page's Delete button seeds the target id
    // and shows this; the modal's Delete button fires the real delete_preset.
    in-out property <bool> show_delete_dialog: false;
    in-out property <string> delete_target_id: "";

    // ── Chat-template preview dialog state ──────────────────────────
    // Purely Slint-side: the Models-page "Chat template" row's Preview button
    // flips this. The raw template text is already in `chat_template_preview`
    // (pushed by Rust on every model change), so opening needs no callback.
    in-out property <bool> show_chat_template_dialog: false;

    // True while any modal dialog is open. The app-wide keyboard shortcuts
    // (app.slint) gate on this so Ctrl+S / Ctrl+N / tab switches can't act on
    // the page hidden behind the backdrop.
    out property <bool> modal_open: show_new_kind_picker || show_rename_dialog
        || show_discard_dialog || show_delete_dialog || show_chat_template_dialog;

    // ── Integrations tab state ─────────────────────────────────────
    in-out property <[IntegrationModel]> integration_models;
    in-out property <bool> integration_provider_active: false;
    in-out property <string> integration_claude_env: "";

    // ── Status / toast ───────────────────────────────────────────────
    in-out property <string> status_text: "";
    in-out property <bool> status_is_error: false;

    // ── Callbacks ────────────────────────────────────────────────────
    callback save_server();
    callback revert_server();
    callback browse_models_dir(string) -> string;

    // GPU distribution table, one set per scope (server-wide / per-preset). Every
    // edit is a whole-selection rewrite in Rust (src/gpu_split.rs): the handler
    // rewrites the form's `device` + `tensor_split` strings, then REBUILDS the row
    // model. Devices are addressed by id, never by row index. See GpuSplitTable's
    // binding note (and why the row ORDER is fixed to the probe's).
    // `*_gpu_move(id, delta)` is the drag handle: move a checked device `delta`
    // places within the split (negative = towards the head). Position 0 is
    // llama.cpp's main_gpu, so this is the only way to choose which GPU leads.
    callback server_gpu_toggle(string);
    callback server_gpu_move(string, int);
    callback server_gpu_weight(string, int);
    callback server_gpu_auto();
    callback server_gpu_even();
    callback preset_gpu_toggle(string);
    callback preset_gpu_move(string, int);
    callback preset_gpu_weight(string, int);
    callback preset_gpu_auto();
    callback preset_gpu_even();

    // Tensor-placement table, one set per scope (server-wide / per-preset). Same
    // shape as the GPU table's: each one rewrites the scope's `override_tensor`
    // string in Rust (src/tensor_override.rs) and rebuilds the row model — except
    // `*_tensor_pattern`, the text field, which must NOT rebuild (that would
    // recreate the LineEdit being typed into and drop the caret), so it refreshes
    // only the derived strings. The int is the ROW INDEX; the string is the picked
    // kind id / device id / regex.
    callback server_tensor_add();
    callback server_tensor_remove(int);
    callback server_tensor_kind(int, string);
    callback server_tensor_device(int, string);
    callback server_tensor_pattern(int, string);

    callback preset_tensor_add();
    callback preset_tensor_remove(int);
    callback preset_tensor_kind(int, string);
    callback preset_tensor_device(int, string);
    callback preset_tensor_pattern(int, string);

    callback select_preset(int);
    callback save_preset();
    callback revert_preset();
    callback delete_preset(string);
    callback new_preset();
    callback clone_preset();
    callback pick_new_empty();
    callback pick_new_clone();
    callback rename_preset(string, string);
    // Rename… button entry point. Routed through Rust (not opened Slint-side)
    // so a dirty form gets the same discard-confirm guard as the other
    // form-replacing navigations — committing a rename reloads from disk.
    callback request_rename();
    // Discard-confirm dialog verdict (see its state block above): confirm runs
    // the stashed pending action, cancel drops it.
    callback confirm_discard();
    callback cancel_discard();
    callback filter_presets(string);
    callback filter_dialog_models(string);
    // Recompute the "Model info" box from the currently selected model file.
    callback model_changed();
    // A row was picked in the draft-model dropdown. The policy (set model_draft +
    // spec_type from the parallel arrays, auto-pin the draft device — the gemma4
    // MTP-crash workaround) lives in Rust (gui/models_tab.rs) where it is
    // unit-tested; the .slint side only reports the picked index.
    callback draft_picked(int);

    callback start_server();
    callback stop_server();
    // Open (or re-focus) the independent log-tail window (LogWindow in
    // log_window.slint) — a separate non-modal root, so the main window stays
    // interactive while it is up. Wired in gui/log_window.rs.
    callback view_logs();
    // Re-read server.ini / presets.ini and re-scan the models directory.
    // Picks up files added on disk or config files edited by hand outside
    // the GUI, without restarting the app.
    callback reload_all();

    callback toggle_integration_model(int);
    callback save_integrations();
    callback revert_integrations();
    callback open_opencode_folder();
}
