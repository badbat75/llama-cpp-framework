// Shared application state for the configurator.
//
// Every property and callback that Rust drives — plus anything more than one
// component reads — lives here, in one exported global, so each datum is
// declared ONCE instead of three times (AppWindow field → forwarding binding →
// page field). The tab pages are conditionally instantiated, so Rust cannot
// reach a property declared on a page: a Rust-driven datum belongs here even
// when a single page reads it. Rust drives the global via
// `app.global::<AppState>()`; the pages read/write `AppState.<name>` directly.
//
// The tray (`AppTray` in app.slint) is a separate root and does NOT use this
// global — it keeps its own pushed-in state.

import { PresetSummary, PresetForm, ServerForm, IntegrationModel } from "types.slint";
import { Options } from "components.slint";

export global AppState {
    // Crate version (CARGO_PKG_VERSION), pushed in from Rust at startup so the
    // title bar always reflects the built version.
    in-out property <string> app_version;

    // ── Navigation ───────────────────────────────────────────────────
    // 0 = Server, 1 = Models, 2 = Integrations.
    in-out property <int> current_tab: 0;

    // ── Live status ──────────────────────────────────────────────────
    in-out property <bool> server_running: false;
    // Transitional flag: Stop has been triggered but the process is still
    // running (a forced kill lingers a moment while the GPU context unwinds).
    // Held true by Rust until `tasklist` confirms the process is gone.
    in-out property <bool> server_stopping: false;
    in-out property <bool> server_status_is_error: false;
    in-out property <string> server_version: "";
    in-out property <string> server_command_line: "";
    // The URL the Open-chat button launches. Derived by Rust from the SAVED
    // server.ini alongside the command line (gui::refresh_server_snapshot):
    // saved port + client_host, which maps a 0.0.0.0 bind to localhost (a
    // listen address is not a connectable one).
    in-out property <string> chat_url: "";

    // ── Server tab state ─────────────────────────────────────────────
    // All editable server.ini fields live in one struct (ServerForm), like the
    // preset side's `form`. Rust drives it via config_to_form / form_to_config
    // (src/server_form.rs); `server_form_base` is the loaded/saved baseline and
    // dirty-tracking is a single struct compare. The bind/device dropdowns below
    // are option lists (not form values), so they stay separate.
    // No Slint-side initializer: Rust seeds both structs from disk before the
    // event loop starts (gui::run() → load_server_into_ui), and the display
    // defaults have ONE owner — server_form::config_to_form.
    in-out property <ServerForm> server_form;
    in-out property <ServerForm> server_form_base;
    out property <bool> server_dirty: server_form != server_form_base;
    // Save gating shared by the Server tab's Save button and the Ctrl+S
    // shortcut (app.slint) — single source so the two can't drift.
    out property <bool> can_save_server: server_dirty;

    // Logical-processor count (std::thread::available_parallelism), pushed from
    // Rust at startup — the upper bound for the CPU-threads / batch-threads
    // sliders. A generous fallback keeps the sliders usable if the probe fails.
    in-out property <int> cpu_threads_max: 32;

    // "Bind to" (hostname) dropdown options, derived from the local interfaces.
    in-out property <[string]> bind_labels;
    in-out property <[string]> bind_values;
    in-out property <int> bind_index: 0;

    // Server-wide GPU-device dropdown triple, derived from the async
    // `--list-devices` probe. The raw device list itself is Rust-only
    // (`devices::probed()`), not published here. The per-preset twins
    // (model + draft device) live under "Models tab state" below.
    in-out property <[string]> server_dev_labels;
    in-out property <[string]> server_dev_values;
    in-out property <int> server_dev_index: 0;

    // ── Models tab state ─────────────────────────────────────────────
    in-out property <[PresetSummary]> presets;
    in-out property <int> selected_preset_index: -1;
    in-out property <PresetForm> form;
    // Baseline snapshot of the loaded preset (set by Rust whenever the form is
    // (re)loaded or saved). Struct inequality drives Save/Revert enabled.
    in-out property <PresetForm> form_base;
    out property <bool> preset_dirty: form != form_base;
    // Save gating shared by the Models tab's Save button and the Ctrl+S
    // shortcut (app.slint) — single source so the two can't drift.
    out property <bool> can_save_preset: selected_preset_index >= 0 && form.id != "" && preset_dirty;
    in-out property <string> presets_path: "";
    in-out property <string> presets_filter: "";

    // Per-preset GPU-device dropdown triples (model device + draft device),
    // fed from the same `devices::probed()` cache as the server-wide triple
    // under "Server tab state" above.
    in-out property <[string]> preset_dev_labels;
    in-out property <[string]> preset_dev_values;
    in-out property <int> preset_dev_index: 0;
    in-out property <[string]> preset_draft_dev_labels;
    in-out property <[string]> preset_draft_dev_values;
    in-out property <int> preset_draft_dev_index: 0;

    // File-field dropdowns for model and mmproj
    in-out property <[string]> model_labels;
    in-out property <[string]> model_values;
    in-out property <int> model_index: -1;
    in-out property <[string]> mmproj_labels;
    in-out property <[string]> mmproj_values;
    in-out property <int> mmproj_index: -1;
    // Unified draft-model picker (MTP heads from mtps\ + DFlash drafters from
    // dflashs\). Only labels + index live here; the per-row (--model-draft,
    // --spec-type) pairs are Rust-only (`State.draft_rows` in gui.rs), read by
    // the draft_picked handler.
    in-out property <[string]> draft_labels;
    in-out property <int> draft_index: -1;

    // Read-only "Model info" box, filled by Rust (model_changed) from the
    // selected model's GGUF header. `model_info_ready` gates between the info
    // rows and a muted placeholder/error note (`model_info_note`).
    in-out property <bool> model_info_ready: false;
    in-out property <string> model_info_note;
    in-out property <string> model_info_kind;
    // MoE-only: how many layers hold experts + the --n-cpu-moe range. Hidden for
    // dense models (`model_info_has_moe`).
    in-out property <bool> model_info_has_moe: false;
    in-out property <string> model_info_moe;
    in-out property <string> model_info_arch_quant;
    in-out property <string> model_info_layers_ctx;
    in-out property <string> model_info_attn;
    in-out property <string> model_info_draft;
    // Optional rows, shown only when a mmproj / draft file is selected.
    in-out property <bool> model_info_has_mmproj: false;
    in-out property <string> model_info_mmproj;
    in-out property <bool> model_info_has_draft_file: false;
    in-out property <string> model_info_draft_file;
    // True when the main model embeds MTP/nextn heads (`<arch>.nextn_predict_layers` > 0):
    // speculative decoding is possible even before an external draft file is picked.
    in-out property <bool> model_info_embeds_mtp: false;
    // Layer counts (block_count) of the selected model and draft, driving the
    // GPU-layers / MoE-CPU-layers / draft-GPU-layers slider maxima. 0 = unknown
    // (metadata unavailable), in which case the sliders fall back to a
    // 0..Options.all_layers range.
    in-out property <int> model_info_n_layer: 0;
    in-out property <int> model_info_draft_n_layer: 0;
    out property <int> gpu_layers_max: model_info_n_layer > 0 ? model_info_n_layer : Options.all_layers;
    out property <int> draft_layers_max: model_info_draft_n_layer > 0 ? model_info_draft_n_layer : Options.all_layers;
    // Speculative-decoding controls are active when a draft model is selected OR
    // the main model embeds MTP heads — otherwise there is nothing to draft with.
    out property <bool> draft_active: form.model_draft != "" || model_info_embeds_mtp;

    // ── New-preset dialog state ─────────────────────────────────────
    in-out property <bool> show_new_kind_picker: false;
    in-out property <string> new_dialog_source_id: "";
    in-out property <[string]> dialog_model_labels;
    in-out property <int> dialog_model_index: -1;
    in-out property <string> dialog_filter: "";

    // ── Rename-preset dialog state ──────────────────────────────────
    in-out property <bool> show_rename_dialog: false;
    in-out property <string> rename_old_id: "";
    in-out property <string> rename_new_id: "";

    // True while any modal dialog is open. The app-wide keyboard shortcuts
    // (app.slint) gate on this so Ctrl+S / Ctrl+N / tab switches can't act on
    // the page hidden behind the backdrop.
    out property <bool> modal_open: show_new_kind_picker || show_rename_dialog;

    // ── Integrations tab state ─────────────────────────────────────
    in-out property <string> integration_base_url: "";
    in-out property <[IntegrationModel]> integration_models;
    in-out property <bool> integration_provider_active: false;
    in-out property <string> integration_claude_env: "";

    // ── Status / toast ───────────────────────────────────────────────
    in-out property <string> status_text: "";
    in-out property <bool> status_is_error: false;

    // ── Callbacks ────────────────────────────────────────────────────
    callback save_server();
    callback revert_server();
    callback browse_models_dir(string) -> string;

    callback select_preset(int);
    callback save_preset();
    callback revert_preset();
    callback delete_preset(string);
    callback new_preset();
    callback clone_preset();
    callback pick_new_empty();
    callback pick_new_clone();
    callback rename_preset(string, string);
    callback filter_presets(string);
    callback filter_dialog_models(string);
    // Recompute the "Model info" box from the currently selected model file.
    callback model_changed();
    // A row was picked in the draft-model dropdown. The policy (set model_draft +
    // spec_type from the parallel arrays, auto-pin the draft device — the gemma4
    // MTP-crash workaround) lives in Rust (gui/models_tab.rs) where it is
    // unit-tested; the .slint side only reports the picked index.
    callback draft_picked(int);

    callback refresh_status();
    callback start_server();
    callback stop_server();
    // Re-read server.ini / presets.ini and re-scan the models directory.
    // Picks up files added on disk or config files edited by hand outside
    // the GUI, without restarting the app.
    callback reload_all();

    callback toggle_integration_model(int);
    callback save_integrations();
    callback revert_integrations();
}
