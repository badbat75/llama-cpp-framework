// ModelsPage: the models tab (preset editor). All state lives in AppState
// (state.slint); this component lays out the widgets against it.
//
// Layout: preset list (left column) | editor cards (right, grep `heading:`):
// Assets → Model info → Hardware Config → Resource / context → KV cache →
// Chat / reasoning → Sampling overrides → Advanced → Speculative decoding,
// then the FormActions row.

import { LineEdit, ComboBox, CheckBox, Button, ListView, ScrollView, Palette, SpinBox } from "std-widgets.slint";
import { SectionCard, LabeledField, InfoRow, SegmentedControl, MappedComboBox, AutoSlider, FormActions, SelectableRow, Tokens, Options } from "components.slint";
import { AppState } from "state.slint";

export component ModelsPage inherits HorizontalLayout {
    padding: 24px;
    spacing: 16px;

    // Left column: preset list
    VerticalLayout {
        width: 240px;
        spacing: 10px;

        Text {
            text: "Presets";
            font-size: 14px;
            font-weight: 600;
            color: Palette.foreground;
        }

        LineEdit {
            placeholder-text: "Filter presets…";
            input-type: search;
            text <=> AppState.presets_filter;
            edited(t) => { AppState.filter_presets(t); }
        }

        Rectangle {
            border-width: 1px;
            border-color: Palette.border;
            border-radius: 8px;
            background: Palette.alternate-background;
            // Keep the floor modest so the Models tab still fits a
            // small screen; vertical-stretch grows it on big ones.
            min-height: 160px;
            vertical-stretch: 1;

            ListView {
                // The Rust side already filtered out non-matching rows, so every
                // delegate is a fixed 36px tall — a data-dependent height confuses
                // ListView's running-sum layout and the rows render on top of each
                // other. `p.orig_index` maps back to the full presets vector.
                for p in AppState.presets : SelectableRow {
                    height: 36px;
                    label: p.id;
                    selected: p.orig_index == AppState.selected_preset_index;
                    clicked => { AppState.select_preset(p.orig_index); }
                }
            }
        }

        VerticalLayout {
            spacing: 6px;
            HorizontalLayout {
                spacing: 6px;
                Button {
                    text: "New…";
                    clicked => { AppState.new_preset(); }
                }
                Button {
                    text: "Clone…";
                    enabled: AppState.selected_preset_index >= 0;
                    clicked => { AppState.clone_preset(); }
                }
            }
            HorizontalLayout {
                spacing: 6px;
                Button {
                    text: "Rename…";
                    enabled: AppState.selected_preset_index >= 0;
                    // Opens its dialog purely Slint-side (seed the fields, show
                    // the modal) — unlike New…/Clone…, which route through Rust
                    // callbacks. The actual rename fires from the dialog in
                    // app.slint (AppState.rename_preset).
                    clicked => {
                        AppState.rename_old_id = AppState.form.id;
                        AppState.rename_new_id = AppState.form.id;
                        AppState.show_rename_dialog = true;
                    }
                }
                Button {
                    text: "Delete";
                    enabled: AppState.selected_preset_index >= 0;
                    clicked => { AppState.delete_preset(AppState.form.id); }
                }
            }
        }

        Text {
            text: AppState.presets_path;
            font-size: 10px;
            color: Palette.foreground.transparentize(Tokens.faint);
            wrap: word-wrap;
        }
    }

    // Right column: editor
    ScrollView {
        horizontal-stretch: 1;
        VerticalLayout {
            padding-left: 4px;
            padding-right: 4px;
            spacing: 16px;

            Text {
                text: AppState.selected_preset_index >= 0
                    ? "Preset id: " + AppState.form.id
                    : "Select a preset on the left, or click New…";
                font-size: 14px;
                font-weight: 600;
                color: Palette.foreground;
            }

            SectionCard {
                heading: "Assets";
                LabeledField {
                    label: "Model file";
                    hint: "Main model weights for this preset (--model / -m).\nPick a .gguf from models\\.";
                    MappedComboBox {
                        labels: AppState.model_labels;
                        values: AppState.model_values;
                        index <=> AppState.model_index;
                        picked(v) => {
                            AppState.form.model = v;
                            AppState.model_changed();
                        }
                    }
                }
                LabeledField {
                    label: "MMProj";
                    hint: "Multimodal projector (--mmproj) for vision models, so the server can read images.\nBlank for text-only models.";
                    MappedComboBox {
                        labels: AppState.mmproj_labels;
                        values: AppState.mmproj_values;
                        index <=> AppState.mmproj_index;
                        picked(v) => {
                            AppState.form.mmproj = v;
                            AppState.model_changed();
                        }
                    }
                }
                LabeledField {
                    label: "Draft model";
                    hint: "Optional speculator (feeds --model-draft).\nMTP heads (from mtps\\) set --spec-type draft-mtp; DFlash drafters (from dflashs\\) set draft-dflash.\nPicking one auto-pins the draft to the server GPU, or CPU if none.\n(none) = no speculation.";
                    // A raw ComboBox (not MappedComboBox): the handler needs the
                    // selected INDEX to read the parallel `draft_specs` array, not
                    // just the picked value. The pick POLICY (spec-type + the
                    // gemma4 auto-pin workaround) lives in Rust — see the
                    // `draft_picked` handler in src/gui/models_tab.rs.
                    ComboBox {
                        model: AppState.draft_labels;
                        current-index <=> AppState.draft_index;
                        selected => { AppState.draft_picked(self.current-index); }
                    }
                }
                LabeledField {
                    label: "Spec type";
                    hint: "Speculative decoding mode (--spec-type).\nAuto-set when you pick a draft model above: MTP heads → draft-mtp, DFlash drafters → draft-dflash.\nOverride only if you know what you need.";
                    ComboBox {
                        // Active only when a draft is available (selected or embedded MTP).
                        enabled: AppState.draft_active;
                        model: ["none", "draft-mtp", "draft-dflash", "draft-simple", "ngram-mod"];
                        // form.spec_type is never "" (preset_to_form maps empty → "none").
                        current-value <=> AppState.form.spec_type;
                    }
                }
            }

            SectionCard {
                heading: "Model info";
                if AppState.model_info_ready : VerticalLayout {
                    spacing: 8px;
                    InfoRow {
                        label: "Type";
                        hint: "Dense runs every weight each token; MoE activates only a few experts, so VRAM ≈ all weights but compute ≈ active experts.\nMoE is what makes the 'MoE CPU layers' lever below useful.";
                        value: AppState.model_info_kind;
                    }
                    if AppState.model_info_has_moe : InfoRow {
                        label: "MoE layers";
                        hint: "How many layers carry expert (FFN) weights — the range for the 'MoE CPU layers' lever (--n-cpu-moe) below.\nRaise it to move more expert layers to CPU: less VRAM, slower generation.";
                        value: AppState.model_info_moe;
                    }
                    InfoRow {
                        label: "Arch / quant";
                        value: AppState.model_info_arch_quant;
                    }
                    InfoRow {
                        label: "Layers / ctx";
                        hint: "block_count guides --n-gpu-layers; the trained context is the sane upper bound for --ctx-size (going higher needs RoPE scaling).";
                        value: AppState.model_info_layers_ctx;
                    }
                    InfoRow {
                        label: "Attention";
                        hint: "Head counts.\nFewer KV heads (GQA) shrink the KV cache, so a higher --ctx-size fits in the same VRAM.";
                        value: AppState.model_info_attn;
                    }
                    if AppState.model_info_has_mmproj : InfoRow {
                        label: "MMProj";
                        hint: "The selected multimodal projector: projector type, modality (vision/audio), encoder depth, and native image / patch size.";
                        value: AppState.model_info_mmproj;
                    }
                    InfoRow {
                        label: "Draft";
                        hint: "Whether the model embeds MTP (next-n) layers, and whether a matching MTP/DFlash drafter sits in your mtps\\ / dflashs\\ folders — pick it as the Draft model in the Assets card above.";
                        value: AppState.model_info_draft;
                    }
                    if AppState.model_info_has_draft_file : InfoRow {
                        label: "Draft file";
                        hint: "The selected draft/MTP/DFlash file's own header: arch, quant, layers, and (DFlash) trained block_size with the implied --spec-draft-n-max ceiling.";
                        value: AppState.model_info_draft_file;
                    }
                }
                if !AppState.model_info_ready : Text {
                    text: AppState.model_info_note == ""
                        ? "Select a model to see its GGUF details."
                        : AppState.model_info_note;
                    font-size: 13px;
                    wrap: word-wrap;
                    color: Palette.foreground.transparentize(Tokens.muted);
                }
            }

            SectionCard {
                heading: "Hardware Config";
                LabeledField {
                    label: "GPU device";
                    hint: "GPU this model runs on (--device, e.g. CUDA0).\nOverrides the server default.\nBlank = use server default.";
                    MappedComboBox {
                        labels: AppState.preset_dev_labels;
                        values: AppState.preset_dev_values;
                        index <=> AppState.preset_dev_index;
                        picked(v) => { AppState.form.device = v; }
                    }
                }
                LabeledField {
                    label: "GPU split mode";
                    hint: "Multi-GPU split for this model (--split-mode), overrides the server default; same on CUDA and HIP.\nlayer splits layers + KV; row is tensor-parallel; none = single GPU.\ndefault = inherit server.\nIgnored when a GPU device pins one device.";
                    ComboBox {
                        // A pinned GPU device runs on one device, so the split
                        // strategy has nothing to split — disable it.
                        enabled: AppState.form.device == "";
                        model: Options.split_modes;
                        // form.split_mode is never "" (preset_to_form maps empty → "default").
                        current-value <=> AppState.form.split_mode;
                    }
                }
                LabeledField {
                    label: "Tensor split";
                    hint: "Per-GPU weight proportions for this model (--tensor-split), e.g. 3,1 (75%/25%).\nOverrides the server default.\nBlank = inherit server / even split.";
                    LineEdit {
                        // Per-GPU proportions only apply across multiple GPUs;
                        // a pinned device makes them moot — disable it.
                        enabled: AppState.form.device == "";
                        text <=> AppState.form.tensor_split;
                        placeholder-text: "e.g. 3,1  (blank = server default)";
                    }
                }
                LabeledField {
                    label: "GPU layers";
                    hint: "--n-gpu-layers: model layers offloaded to GPU.\nSlider max = the model's layer count (all on GPU); lower keeps layers on CPU to save VRAM.\nauto = omit the flag → llama.cpp offloads ALL layers to GPU (the framework runs with -fit off, so there is no auto-fit to VRAM — a model too big to fit will fail to load).";
                    AutoSlider {
                        auto <=> AppState.form.n_gpu_layers_auto;
                        value <=> AppState.form.n_gpu_layers;
                        maximum: AppState.gpu_layers_max;
                    }
                }
                LabeledField {
                    label: "MoE CPU layers";
                    hint: "Number of Mixture-of-Experts layers whose expert (FFN) weights stay on CPU (--n-cpu-moe) to save VRAM.\nOnly affects MoE models; N/A for dense models like Gemma.\nSlider max = the model's layer count.\nauto = omit the flag → equivalent to 0: no expert weights are kept on CPU, so every expert stays on GPU with its layer.";
                    // --n-cpu-moe only affects MoE models, so gate the whole row on it.
                    AutoSlider {
                        auto <=> AppState.form.n_cpu_moe_auto;
                        value <=> AppState.form.n_cpu_moe;
                        maximum: AppState.gpu_layers_max;  // = the model's layer count
                        usable: AppState.model_info_has_moe;
                    }
                }
                LabeledField {
                    label: "Draft device";
                    hint: "GPU for the draft model (--device-draft).\nPin to ONE device — multi-GPU auto-split crashes MTP heads.\nBlank = auto / same as model.";
                    MappedComboBox {
                        // Active only when a draft is available (selected or embedded MTP).
                        enabled: AppState.draft_active;
                        labels: AppState.preset_draft_dev_labels;
                        values: AppState.preset_draft_dev_values;
                        index <=> AppState.preset_draft_dev_index;
                        picked(v) => { AppState.form.device_draft = v; }
                    }
                }
                LabeledField {
                    label: "Draft GPU layers";
                    hint: "Draft-model layers offloaded to GPU (--n-gpu-layers-draft).\nA drafter with real layers (e.g. DFlash) gets a 0..layer-count slider.\nAn MTP/nextn head has no transformer layers (block_count 0), so it becomes a plain CPU/GPU switch.\nPin a device above — multi-GPU auto-split crashes MTP heads.\nauto = omit the flag → llama.cpp offloads ALL draft layers to GPU.";
                    // Real drafter (block_count > 0): the same auto + slider +
                    // readout row as the other layer knobs — one canonical
                    // implementation (AutoSlider) instead of an inline copy.
                    if AppState.model_info_draft_n_layer > 0 : AutoSlider {
                        auto <=> AppState.form.n_gpu_layers_draft_auto;
                        value <=> AppState.form.n_gpu_layers_draft;
                        maximum: AppState.draft_layers_max;
                        // Active only when a draft is available (selected or embedded MTP).
                        usable: AppState.draft_active;
                    }
                    // MTP/nextn head (0 layers) or no header: auto checkbox + a
                    // binary CPU/GPU choice. A SegmentedControl (not a Switch):
                    // its highlight is a pure read of the model, so it never goes
                    // stale after a click — a Switch's `checked` self-assignment
                    // would break its one-way binding (the v1.1.1 staleness
                    // class). on GPU = all draft layers, on CPU = 0.
                    if AppState.model_info_draft_n_layer == 0 : CheckBox {
                        text: "auto";
                        // Active only when a draft is available (selected or embedded MTP).
                        enabled: AppState.draft_active;
                        checked <=> AppState.form.n_gpu_layers_draft_auto;
                    }
                    if AppState.model_info_draft_n_layer == 0 : SegmentedControl {
                        horizontal-stretch: 1;
                        enabled: !AppState.form.n_gpu_layers_draft_auto && AppState.draft_active;
                        options: ["on GPU", "on CPU"];
                        current: AppState.form.n_gpu_layers_draft >= 1 ? "on GPU" : "on CPU";
                        activated(v) => { AppState.form.n_gpu_layers_draft = v == "on GPU" ? Options.all_layers : 0; }
                    }
                }
            }

            SectionCard {
                heading: "Resource / context";
                LabeledField {
                    label: "Context size";
                    hint: "Context window in tokens (--ctx-size).\nBigger = longer history but more KV-cache VRAM; split across parallel slots.";
                    SpinBox {
                        // Type a value or use the steppers. The maximum is set far
                        // above any real value so it never clamps typed input.
                        // accessible-label is also the handle the headless UI test
                        // (src/tests/ui_bindings.rs) finds this field by.
                        accessible-label: "preset-ctx-size";
                        horizontal-stretch: 1;
                        minimum: 0;
                        maximum: 100000000;
                        value <=> AppState.form.ctx_size;
                    }
                }
                LabeledField {
                    label: "Parallel seqs";
                    hint: "--parallel: concurrent request slots.\nContext is divided among them, so N=4 gives each slot ctx-size / 4 tokens.";
                    SpinBox {
                        horizontal-stretch: 1;
                        minimum: 0;
                        maximum: 100000;
                        value <=> AppState.form.parallel;
                    }
                }
                LabeledField {
                    label: "Batch size";
                    hint: "--batch-size: logical batch (tokens prefilled per step).\nHigher speeds prefill, uses more VRAM.";
                    SpinBox {
                        horizontal-stretch: 1;
                        minimum: 0;
                        maximum: 100000000;
                        value <=> AppState.form.batch_size;
                    }
                }
                LabeledField {
                    label: "U-Batch size";
                    hint: "--ubatch-size: physical micro-batch computed at once.\nMust be ≤ batch size.";
                    SpinBox {
                        horizontal-stretch: 1;
                        minimum: 0;
                        maximum: 100000000;
                        value <=> AppState.form.ubatch_size;
                    }
                }
            }

            SectionCard {
                heading: "KV cache";
                LabeledField {
                    label: "K-cache type";
                    hint: "KV cache quantization.\nLower = less VRAM but lower quality.\nNote: Qwen3-Coder needs q8_0 for reliable tool calling — q4_0 makes it drop the <tool_call> wrapper.";
                    ComboBox {
                        model: Options.cache_types;
                        current-value <=> AppState.form.cache_type_k;
                    }
                }
                LabeledField {
                    label: "V-cache type";
                    hint: "KV cache quantization for V (--cache-type-v).\nLower = less VRAM, lower quality; usually matched to K.\nNeeds flash attention.";
                    ComboBox {
                        model: Options.cache_types;
                        current-value <=> AppState.form.cache_type_v;
                    }
                }
                LabeledField {
                    label: "Flash Attention";
                    hint: "Enables the fused flash-attention kernel (-fa): faster prefill and lower KV memory.\nRecommended on; required for quantized KV cache to help on most backends.";
                    CheckBox {
                        text: "enable flash attention (-fa)";
                        checked <=> AppState.form.flash_attn;
                    }
                }
                LabeledField {
                    label: "Cache RAM (MiB)";
                    hint: "--cache-ram: RAM limit (MiB) for the prompt cache (past-prompt KV kept for reuse).\nBlank = default; 0 disables.";
                    LineEdit {
                        text <=> AppState.form.cache_ram;
                        input-type: number;
                        placeholder-text: "8192";
                    }
                }
            }

            SectionCard {
                heading: "Chat / reasoning";
                LabeledField {
                    label: "Chat template";
                    hint: "--jinja: use the model's embedded Jinja chat template instead of built-in heuristics.\nRecommended on for correct tool-call / role formatting.";
                    CheckBox {
                        text: "use embedded chat template (--jinja)";
                        checked <=> AppState.form.jinja;
                    }
                }
                LabeledField {
                    label: "Reasoning";
                    hint: "auto: model decides (for Gemma auto≡on).\non: force thinking.\noff: disable.\nNote reasoning=on can invalidate the KV cache mid-conversation; prefer auto.";
                    // A RadioGroup imperatively sets each button's `checked` on
                    // selection, which breaks the binding and leaves the pick stale
                    // on preset switch. SegmentedControl derives its highlight purely
                    // from `current`, so it stays in sync.
                    SegmentedControl {
                        options: ["auto", "on", "off"];
                        current: AppState.form.reasoning == "" ? "auto" : AppState.form.reasoning;
                        activated(value) => { AppState.form.reasoning = value; }
                    }
                }
                LabeledField {
                    label: "Reason format";
                    hint: "--reasoning-format: how thinking output is delivered.\nauto = let the template decide; deepseek = parse <think> blocks into a separate reasoning channel; none = inline.";
                    SegmentedControl {
                        options: ["auto", "none", "deepseek"];
                        current: AppState.form.reasoning_format == "" ? "auto" : AppState.form.reasoning_format;
                        activated(value) => { AppState.form.reasoning_format = value; }
                    }
                }
            }

            SectionCard {
                heading: "Sampling overrides (blank = unset)";
                LabeledField {
                    label: "Temperature";
                    hint: "--temp: sampling temperature.\nLower = more deterministic, higher = more creative.\nBlank = default.";
                    LineEdit {
                        // accessible-label is also the handle the headless UI test
                        // (src/tests/ui_bindings.rs) finds this field by.
                        accessible-label: "preset-temp";
                        text <=> AppState.form.temp;
                        placeholder-text: "default";
                    }
                }
                LabeledField {
                    label: "Top-K";
                    hint: "--top-k: keep only the K most-likely tokens before sampling.\n0 / blank = disabled.";
                    LineEdit {
                        text <=> AppState.form.top_k;
                        input-type: number;
                        placeholder-text: "default";
                    }
                }
                LabeledField {
                    label: "Top-P";
                    hint: "--top-p: nucleus sampling — smallest token set whose probabilities sum to P (e.g. 0.95).\nBlank = default.";
                    LineEdit {
                        text <=> AppState.form.top_p;
                        placeholder-text: "default";
                    }
                }
                LabeledField {
                    label: "Min-P";
                    hint: "--min-p: drop tokens below this fraction of the top token's probability.\nBlank = default.";
                    LineEdit {
                        text <=> AppState.form.min_p;
                        placeholder-text: "default";
                    }
                }
                LabeledField {
                    label: "Repeat penalty";
                    hint: "--repeat-penalty: >1 discourages repeating recent tokens (e.g. 1.1).\nBlank = default.";
                    LineEdit {
                        text <=> AppState.form.repeat_penalty;
                        placeholder-text: "default";
                    }
                }
                LabeledField {
                    label: "Presence penalty";
                    hint: "--presence-penalty: positive values discourage reusing any seen token, pushing new topics.\nBlank = default.";
                    LineEdit {
                        text <=> AppState.form.presence_penalty;
                        placeholder-text: "default";
                    }
                }
            }

            SectionCard {
                heading: "Advanced";
                LabeledField {
                    label: "Chat kwargs";
                    hint: "--chat-template-kwargs: JSON merged into the chat template, e.g. {\"enable_thinking\":true}.\nAdvanced — leave blank unless the model documents kwargs.";
                    LineEdit {
                        text <=> AppState.form.chat_template_kwargs;
                        placeholder-text: "e.g. {\"temperature\":0.7}";
                    }
                }
            }

            SectionCard {
                heading: "Speculative decoding (MTP / DFlash)";
                LabeledField {
                    label: "Draft n-max";
                    hint: "Max draft tokens proposed per step.\nDFlash clamps this to the GGUF's trained block_size-1 (e.g. 15).\nBlank = model default.";
                    LineEdit {
                        // Active only when a draft is available (selected or embedded MTP).
                        enabled: AppState.draft_active;
                        text <=> AppState.form.spec_draft_n_max;
                        input-type: number;
                        placeholder-text: "blank = default";
                    }
                }
            }

            FormActions {
                save_text: "Save preset";
                // Shared with the Ctrl+S shortcut — the gate lives in state.slint.
                save_enabled: AppState.can_save_preset;
                revert_enabled: AppState.selected_preset_index >= 0 && AppState.preset_dirty;
                save => { AppState.save_preset(); }
                revert => { AppState.revert_preset(); }
            }
        }
    }
}
