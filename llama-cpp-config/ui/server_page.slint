// ServerPage: the server tab. All state lives in AppState (state.slint); this
// component just lays out the widgets against it.
//
// Layout (grep `heading:`): Network → Resources → Command Line cards, then the
// FormActions row.
//
// Editable widgets bind two-way (`<=>`): a one-way binding breaks the moment the
// user types/toggles (Slint's "overwritten bindings" rule), which would leave the
// field stale after a Revert / reload.

import { LineEdit, TextEdit, ComboBox, CheckBox, Button, ScrollView, Palette } from "std-widgets.slint";
import { SectionCard, LabeledField, MappedComboBox, AutoSlider, FormActions, SplitFields, Tokens, Options } from "components.slint";
import { AppState } from "state.slint";

export component ServerPage inherits ScrollView {
    VerticalLayout {
        padding: 24px;
        spacing: 16px;
        alignment: start;

        Text {
            text: "Server";
            font-size: 22px;
            font-weight: 600;
            color: Palette.foreground;
        }
        Text {
            text: "Machine-wide llama-server settings (server.ini). Per-model knobs live under Models.";
            color: Palette.foreground.transparentize(Tokens.muted);
            font-size: 12px;
            wrap: word-wrap;
        }

        SectionCard {
            heading: "Network";
            LabeledField {
                label: "Port";
                hint: "TCP port llama-server listens on (--port).\nDefault 8080 — the chat UI and integrations connect here.";
                LineEdit {
                    // accessible-label doubles as the stable handle the headless
                    // UI test (src/tests/ui_bindings.rs) uses to find this field.
                    accessible-label: "server-port";
                    text <=> AppState.server_form.port;
                    input-type: number;
                    placeholder-text: "8080";
                }
            }
            LabeledField {
                label: "Bind to";
                hint: "Interface to bind (--host).\nlocalhost = this PC only; 0.0.0.0 = all interfaces, reachable from the LAN.";
                MappedComboBox {
                    labels: AppState.bind_labels;
                    values: AppState.bind_values;
                    index <=> AppState.bind_index;
                    picked(v) => { AppState.server_form.hostname = v; }
                }
            }
        }

        SectionCard {
            heading: "Resources";
            LabeledField {
                label: "Mlock (lock RAM)";
                hint: "Locks model weights into physical RAM (--mlock) so the OS can't page them out.\nKeeps latency stable; needs enough free RAM for the whole model.";
                CheckBox {
                    text: "lock model in physical RAM";
                    checked <=> AppState.server_form.mlock;
                }
            }
            LabeledField {
                label: "CPU threads";
                hint: "--threads: CPU threads for generation.\nauto = omit the flag; llama.cpp defaults to the physical-core count it detects. More won't help once GPU-bound. Max = logical processors.";
                AutoSlider {
                    auto <=> AppState.server_form.threads_auto;
                    value <=> AppState.server_form.threads;
                    maximum: AppState.cpu_threads_max;
                    slider-label: "server-threads";
                }
            }
            LabeledField {
                label: "Cache reuse";
                hint: "--cache-reuse: minimum prefix length (tokens) the server reuses from the KV cache across requests, skipping re-prefill.\nHigher saves compute on shared prefixes.";
                LineEdit {
                    text <=> AppState.server_form.cache_reuse;
                    input-type: number;
                    placeholder-text: "256";
                }
            }
            LabeledField {
                label: "Batch threads";
                hint: "--threads-batch: CPU threads for prompt processing (prefill).\nauto = omit the flag; llama.cpp defaults it to the same as --threads. Max = logical processors.";
                AutoSlider {
                    auto <=> AppState.server_form.threads_batch_auto;
                    value <=> AppState.server_form.threads_batch;
                    maximum: AppState.cpu_threads_max;
                }
            }
            LabeledField {
                label: "Max models";
                hint: "--models-max: how many preset models llama-server keeps resident at once.\n1 = load one at a time (lowest VRAM); higher lets it hot-swap without reloading.";
                LineEdit {
                    text <=> AppState.server_form.models_max;
                    input-type: number;
                    placeholder-text: "1 (one at a time)";
                }
            }
            LabeledField {
                label: "Models folder";
                hint: "Root folder scanned for GGUFs.\nPickers read its subfolders: models\\, mmprojs\\, mtps\\, dflashs\\.";
                LineEdit {
                    text <=> AppState.server_form.models_dir;
                    placeholder-text: "root dir (models\\ and mmprojs\\ underneath)";
                }
                Button {
                    text: "Browse…";
                    clicked => {
                        AppState.server_form.models_dir = AppState.browse_models_dir(AppState.server_form.models_dir);
                    }
                }
            }
            LabeledField {
                label: "GPU device";
                hint: "Default GPU for all presets (--device, e.g. CUDA0).\nA per-preset GPU device overrides it.\nBlank = all detected devices.";
                MappedComboBox {
                    labels: AppState.server_dev_labels;
                    values: AppState.server_dev_values;
                    index <=> AppState.server_dev_index;
                    picked(v) => { AppState.server_form.device = v; }
                }
            }
            // Disabled when the GPU device above pins one device; server_form.split_mode
            // holds "default" when unset (config_to_form). See SplitFields.
            SplitFields {
                device: AppState.server_form.device;
                split_mode <=> AppState.server_form.split_mode;
                tensor_split <=> AppState.server_form.tensor_split;
                split_mode_hint: "Multi-GPU split strategy (--split-mode), same on CUDA and HIP.\nlayer (default) splits layers + KV across GPUs; row splits per-row (tensor-parallel, more PCIe traffic); none = single GPU.\nIgnored when GPU device pins one device.";
                tensor_split_hint: "Per-GPU weight proportions (--tensor-split), e.g. 3,1 to put 75% on the first GPU and 25% on the second (useful when GPUs differ in VRAM).\nBlank = even split.";
                tensor_split_placeholder: "e.g. 3,1  (blank = even)";
            }
        }

        SectionCard {
            heading: "Command Line";
            content_padding: 12px;
            // Read-only, multi-line view of the exact llama-server
            // invocation `Start` would run. Rust formats it one
            // `--flag value` per line, joined with the shell's
            // line-continuation char (`` ` `` on Windows, `\` on
            // POSIX), so it pastes straight into a terminal.
            TextEdit {
                text: AppState.server_command_line;
                read-only: true;
                wrap: word-wrap;
                min-height: 160px;
            }
        }

        FormActions {
            save_text: "Save changes";
            // Shared with the Ctrl+S shortcut — the gate lives in state.slint.
            save_enabled: AppState.can_save_server;
            revert_enabled: AppState.server_dirty;
            save => { AppState.save_server(); }
            revert => { AppState.revert_server(); }
        }
    }
}
