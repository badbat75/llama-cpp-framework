// ServerPage: the server tab. All state lives in AppState (state.slint); this
// component just lays out the widgets against it.
//
// Editable widgets bind two-way (`<=>`): a one-way binding breaks the moment the
// user types/toggles (Slint's "overwritten bindings" rule), which would leave the
// field stale after a Revert / reload.

import { LineEdit, TextEdit, ComboBox, CheckBox, Button, ListView, ScrollView, Palette, RadioGroup, Slider, Switch, SpinBox } from "std-widgets.slint";
import { SectionCard, LabeledField } from "components.slint";
import { AppState } from "state.slint";

export component ServerPage inherits ScrollView {
    VerticalLayout {
        padding: 24px;
        spacing: 16px;
        alignment: start;

        Text {
            text: "Server";
            font-size: 22px;
            font-weight: 600;
            color: Palette.foreground;
        }
        Text {
            text: "Machine-wide llama-server settings (server.ini). Per-model knobs live under Models.";
            color: Palette.foreground.transparentize(0.4);
            font-size: 12px;
            wrap: word-wrap;
        }

        SectionCard {
            heading: "Network";
            LabeledField {
                label: "Port";
                hint: "TCP port llama-server listens on (--port).\nDefault 8080 — the chat UI and integrations connect here.";
                LineEdit {
                    text <=> AppState.server_port;
                    input-type: number;
                    placeholder-text: "8080";
                }
            }
            LabeledField {
                label: "Bind to";
                hint: "Interface to bind (--host).\nlocalhost = this PC only; 0.0.0.0 = all interfaces, reachable from the LAN.";
                ComboBox {
                    model: AppState.bind_labels;
                    current-index <=> AppState.bind_index;
                    selected(value) => {
                        let i = self.current-index;
                        if (i >= 0 && i < AppState.bind_values.length) {
                            AppState.server_hostname = AppState.bind_values[i];
                        }
                    }
                }
            }
        }

        SectionCard {
            heading: "Resources";
            LabeledField {
                label: "Mlock (lock RAM)";
                hint: "Locks model weights into physical RAM (--mlock) so the OS can't page them out.\nKeeps latency stable; needs enough free RAM for the whole model.";
                CheckBox {
                    text: "lock model in physical RAM";
                    checked <=> AppState.server_mlock;
                }
            }
            LabeledField {
                label: "CPU threads";
                hint: "--threads: CPU threads for generation.\nBlank = half the physical-core count; more won't help once GPU-bound.";
                LineEdit {
                    text <=> AppState.server_threads;
                    input-type: number;
                    placeholder-text: "blank = half the physical-core count";
                }
            }
            LabeledField {
                label: "Cache reuse";
                hint: "--cache-reuse: minimum prefix length (tokens) the server reuses from the KV cache across requests, skipping re-prefill.\nHigher saves compute on shared prefixes.";
                LineEdit {
                    text <=> AppState.server_cache_reuse;
                    input-type: number;
                    placeholder-text: "256";
                }
            }
            LabeledField {
                label: "Batch threads";
                hint: "--threads-batch: CPU threads for prompt processing (prefill).\nBlank = ~75% of cores.";
                LineEdit {
                    text <=> AppState.server_threads_batch;
                    input-type: number;
                    placeholder-text: "blank = 75% of cores";
                }
            }
            LabeledField {
                label: "Max models";
                hint: "--models-max: how many preset models llama-server keeps resident at once.\n1 = load one at a time (lowest VRAM); higher lets it hot-swap without reloading.";
                LineEdit {
                    text <=> AppState.server_models_max;
                    input-type: number;
                    placeholder-text: "1 (one at a time)";
                }
            }
            LabeledField {
                label: "Models folder";
                hint: "Root folder scanned for GGUFs.\nPickers read its subfolders: models\\, mmprojs\\, mtps\\, dflashs\\.";
                LineEdit {
                    text <=> AppState.server_models_dir;
                    placeholder-text: "root dir (models\\ and mmprojs\\ underneath)";
                }
                Button {
                    text: "Browse…";
                    clicked => {
                        AppState.server_models_dir = AppState.browse_models_dir(AppState.server_models_dir);
                    }
                }
            }
            LabeledField {
                label: "GPU device";
                hint: "Default GPU for all presets (--device, e.g. CUDA0).\nA per-preset GPU device overrides it.\nBlank = all detected devices.";
                ComboBox {
                    model: AppState.server_dev_labels;
                    current-index <=> AppState.server_dev_index;
                    selected(value) => {
                        let i = self.current-index;
                        if (i >= 0 && i < AppState.server_dev_values.length) {
                            AppState.server_device = AppState.server_dev_values[i];
                        }
                    }
                }
            }
            LabeledField {
                label: "GPU split mode";
                hint: "Multi-GPU split strategy (--split-mode), same on CUDA and HIP.\nlayer (default) splits layers + KV across GPUs; row splits per-row (tensor-parallel, more PCIe traffic); none = single GPU.\nIgnored when GPU device pins one device.";
                ComboBox {
                    // A pinned GPU device runs on one device, so there is
                    // nothing to split — disable it.
                    enabled: AppState.server_device == "";
                    model: ["default", "none", "layer", "row"];
                    // server_split_mode holds "default" when unset (see load_server_into_ui).
                    current-value <=> AppState.server_split_mode;
                }
            }
            LabeledField {
                label: "Tensor split";
                hint: "Per-GPU weight proportions (--tensor-split), e.g. 3,1 to put 75% on the first GPU and 25% on the second (useful when GPUs differ in VRAM).\nBlank = even split.";
                LineEdit {
                    // Per-GPU proportions only apply across multiple GPUs;
                    // a pinned device makes them moot — disable it.
                    enabled: AppState.server_device == "";
                    text <=> AppState.server_tensor_split;
                    placeholder-text: "e.g. 3,1  (blank = even)";
                }
            }
        }

        SectionCard {
            heading: "Command Line";
            content_padding: 12px;
            // Read-only, multi-line view of the exact llama-server
            // invocation `Start` would run. Rust formats it one
            // `--flag value` per line, joined with the shell's
            // line-continuation char (`` ` `` on Windows, `\` on
            // POSIX), so it pastes straight into a terminal.
            TextEdit {
                text: AppState.server_command_line;
                read-only: true;
                wrap: word-wrap;
                min-height: 160px;
            }
        }

        HorizontalLayout {
            alignment: end;
            spacing: 8px;
            Button {
                text: "Revert";
                enabled: AppState.server_dirty;
                clicked => { AppState.revert_server(); }
            }
            Button {
                text: "Save changes";
                primary: true;
                enabled: AppState.server_dirty;
                clicked => { AppState.save_server(); }
            }
        }
    }
}
