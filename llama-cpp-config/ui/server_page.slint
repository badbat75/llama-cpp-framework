// ServerPage: the server tab. All state lives in AppState (state.slint); this
// component just lays out the widgets against it.
//
// Layout (grep `heading:`): Network → Resources → GPU distribution → Advanced
// cards, then the FormActions row (Save/Revert), then the Command Line card
// last. The Command
// Line card auto-sizes to its content (a hidden mirror-Text drives its height) so
// it never shows its own inner scrollbar — the page's own ScrollView handles it.
//
// Editable widgets bind two-way (`<=>`): a one-way binding breaks the moment the
// user types/toggles (Slint's "overwritten bindings" rule), which would leave the
// field stale after a Revert / reload.

import { LineEdit, TextEdit, CheckBox, SpinBox, Button, ScrollView, Palette } from "std-widgets.slint";
import { SectionCard, LabeledField, MappedComboBox, AutoSlider, DefaultSpinBox, FormActions, GpuSplitTable, Tokens } from "components.slint";
import { AppState } from "state.slint";

export component ServerPage inherits ScrollView {
    VerticalLayout {
        padding: 24px;
        spacing: 16px;
        alignment: start;

        Text {
            text: "Server";
            font-size: 22px;
            font-weight: 600;
            color: Palette.foreground;
        }
        Text {
            text: "Machine-wide llama-server settings (server.ini). Per-model knobs live under Models.";
            color: Palette.foreground.transparentize(Tokens.muted);
            font-size: 12px;
            wrap: word-wrap;
        }

        SectionCard {
            heading: "Network";
            LabeledField {
                label: "Port";
                hint: "TCP port llama-server listens on (--port).\ndefault = omit the flag → llama.cpp default: 8080. The chat UI and integrations connect here.";
                DefaultSpinBox {
                    spinbox_label: "server-port";
                    default <=> AppState.server_form.port_default;
                    value <=> AppState.server_form.port;
                    maximum: 65535;
                }
            }
            LabeledField {
                label: "Bind to";
                hint: "Interface to bind (--host).\nlocalhost = this PC only; 0.0.0.0 = all interfaces, reachable from the LAN.";
                MappedComboBox {
                    labels: AppState.bind_labels;
                    values: AppState.bind_values;
                    index <=> AppState.bind_index;
                    picked(v) => { AppState.server_form.hostname = v; }
                }
            }
        }

        SectionCard {
            heading: "Resources";
            LabeledField {
                label: "Mlock (lock RAM)";
                hint: "Locks model weights into physical RAM (--mlock) so the OS can't page them out.\nKeeps latency stable; needs enough free RAM for the whole model.";
                CheckBox {
                    text: "lock model in physical RAM";
                    checked <=> AppState.server_form.mlock;
                }
            }
            LabeledField {
                label: "No mmap";
                hint: "Reads the weights into RAM instead of memory-mapping the GGUF (--no-mmap).\nSlower to load and costs the model's size in RAM, but the pages can't be dropped back to the file. Pairs with Mlock, which only locks what is already resident.\ndefault = off (llama.cpp mmaps the file).";
                CheckBox {
                    text: "read weights into RAM instead of mmap";
                    checked <=> AppState.server_form.no_mmap;
                }
            }
            LabeledField {
                label: "CPU threads";
                hint: "--threads: CPU threads for generation.\ndefault = omit the flag → llama.cpp auto-detects the physical-core count. More won't help once GPU-bound. Max = logical processors.";
                AutoSlider {
                    auto <=> AppState.server_form.threads_auto;
                    value <=> AppState.server_form.threads;
                    maximum: AppState.cpu_threads_max;
                    slider_label: "server-threads";
                }
            }
            LabeledField {
                label: "Cache reuse";
                hint: "--cache-reuse: minimum prefix length (tokens) the server reuses from the KV cache across requests, skipping re-prefill.\nHigher saves compute on shared prefixes.\ndefault = omit the flag → llama.cpp default: 0 (disabled).";
                DefaultSpinBox {
                    default <=> AppState.server_form.cache_reuse_default;
                    value <=> AppState.server_form.cache_reuse;
                    minimum: 1;
                }
            }
            LabeledField {
                label: "Batch threads";
                hint: "--threads-batch: CPU threads for prompt processing (prefill).\ndefault = omit the flag → llama.cpp defaults to the same as --threads. Max = logical processors.";
                AutoSlider {
                    auto <=> AppState.server_form.threads_batch_auto;
                    value <=> AppState.server_form.threads_batch;
                    maximum: AppState.cpu_threads_max;
                }
            }
            LabeledField {
                label: "Max models";
                hint: "--models-max: how many preset models llama-server keeps resident at once.\n1 = load one at a time (lowest VRAM); higher lets it hot-swap without reloading.\ndefault = omit the flag → llama.cpp default: 4.\n0 = unlimited.";
                DefaultSpinBox {
                    default <=> AppState.server_form.models_max_default;
                    value <=> AppState.server_form.models_max;
                    maximum: 100000;
                }
            }
            LabeledField {
                label: "Models folder";
                hint: "Root folder scanned for GGUFs.\nPickers read its subfolders: models\\, mmprojs\\, mtps\\, dflashs\\.";
                LineEdit {
                    text <=> AppState.server_form.models_dir;
                    placeholder-text: "root dir (models\\ and mmprojs\\ underneath)";
                }
                Button {
                    text: "Browse…";
                    clicked => {
                        AppState.server_form.models_dir = AppState.browse_models_dir(AppState.server_form.models_dir);
                    }
                }
            }
        }

        SectionCard {
            heading: "GPU distribution";
            Text {
                text: "Default for every preset (--device / --tensor-split). Check the GPUs a model may use and, if they differ in VRAM, how much of it each takes. The checked rows, top to bottom, are the split order — drag ≡ to reorder; the first one is llama.cpp's main GPU (the only one used with split mode 'none'). A preset can override this — unless something is checked here, in which case the server-wide choice wins at launch.";
                wrap: word-wrap;
                font-size: 12px;
                color: Palette.foreground.transparentize(Tokens.muted);
            }
            GpuSplitTable {
                rows: AppState.server_gpu_rows;
                summary: AppState.server_gpu_summary;
                selected: AppState.server_gpu_selected;
                weight_total: AppState.server_gpu_total;
                split_mode <=> AppState.server_form.split_mode;
                split_mode_hint: "Multi-GPU split strategy (--split-mode), same on CUDA and HIP.\nlayer (default) splits layers + KV across GPUs; row splits per-row (tensor-parallel, more PCIe traffic); none = single GPU.\nIrrelevant with one GPU checked.";
                toggled(id) => { AppState.server_gpu_toggle(id); }
                reordered(id, delta) => { AppState.server_gpu_move(id, delta); }
                weight_edited(id, w) => { AppState.server_gpu_weight(id, w); }
                auto_split() => { AppState.server_gpu_auto(); }
                even_split() => { AppState.server_gpu_even(); }
            }
            LabeledField {
                label: "Vision encoder";
                hint: "GPU for the multimodal projector — the mmproj/CLIP image encoder (MTMD_BACKEND_DEVICE).\nIt does NOT follow --device: llama.cpp puts the encoder on the FIRST GPU backend it finds, which on a mixed box is often not the one running the model. It then holds VRAM there and stays idle until an image arrives.\ndefault = that first GPU. Set it to the model's GPU to keep everything on one card.";
                MappedComboBox {
                    labels: AppState.mmproj_dev_labels;
                    values: AppState.mmproj_dev_values;
                    index <=> AppState.mmproj_dev_index;
                    picked(v) => { AppState.server_form.mmproj_device = v; }
                }
            }
        }

        SectionCard {
            heading: "Advanced";
            LabeledField {
                label: "Web UI MCP proxy";
                hint: "Enable the built-in chat UI's MCP CORS proxy (--webui-mcp-proxy).\nThe bundled chat UI needs it to call MCP tools. Experimental upstream — don't enable on an untrusted network.\ndefault = on.";
                CheckBox {
                    text: "serve the web UI's MCP proxy endpoint";
                    checked <=> AppState.server_form.webui_mcp_proxy;
                }
            }
            LabeledField {
                label: "Fit to VRAM";
                hint: "Let llama.cpp auto-shrink unset arguments to fit device memory (-fit on|off).\nOff by default: a preset's 'default' n-gpu-layers means 'offload every layer', which -fit on would silently override.\ndefault = off.";
                CheckBox {
                    text: "auto-fit unset args to device memory (-fit on)";
                    checked <=> AppState.server_form.fit;
                }
            }
            LabeledField {
                label: "Log level";
                hint: "llama-server log verbosity threshold (-lv / --log-verbosity).\nMessages above this level are dropped; higher = more detail.\nFramework default 4 records per-request logging into logs/llama-server.log.";
                SpinBox {
                    value <=> AppState.server_form.log_verbosity;
                    minimum: 0;
                    maximum: 10;
                }
            }
        }

        FormActions {
            save_text: "Save changes";
            // Shared with the Ctrl+S shortcut — the gate lives in state.slint.
            save_enabled: AppState.can_save_server;
            revert_enabled: AppState.server_dirty;
            save => { AppState.save_server(); }
            revert => { AppState.revert_server(); }
        }

        SectionCard {
            heading: "Command Line";
            content_padding: 12px;
            // Read-only, multi-line view of the exact llama-server
            // invocation `Start` would run. Rust formats it one
            // `--flag value` per line, joined with the shell's
            // line-continuation char (`` ` `` on Windows, `\` on
            // POSIX), so it pastes straight into a terminal.
            //
            // Auto-height: the box sizes to a hidden mirror Text that wraps the
            // same string, so the whole command shows at once with no inner
            // scrollbar (the page's own ScrollView handles overflow). It stays a
            // read-only TextEdit, not a plain Text, so the command remains
            // selectable/copyable (Ctrl+C) — the same reason the chat-template
            // preview is a TextEdit (app.slint). Neither the mirror nor the
            // TextEdit sets a font, so both render at the same default metrics
            // and the mirror's height matches the TextEdit's wrapped content.
            Rectangle {
                // Height tracks the wrapped content so the box never shows its
                // own scrollbar (it re-derives only on Save/Revert/load, when the
                // command string itself changes). The mirror Text (12px narrower
                // per side) wraps at least as often as the TextEdit's text area,
                // so it can only OVER-count lines; then +48px clears the
                // TextEdit's border + top/bottom padding, which measured ~one text
                // line taller than the bare mirror (a +24px buffer left the box
                // one line short, so the scrollbar came back).
                height: mirror.preferred-height + 48px;
                mirror := Text {
                    x: 12px;
                    width: parent.width - 24px;
                    text: AppState.server_command_line;
                    wrap: word-wrap;
                    visible: false;
                }
                TextEdit {
                    width: 100%;
                    height: 100%;
                    text: AppState.server_command_line;
                    read-only: true;
                    wrap: word-wrap;
                }
            }
        }
    }
}
