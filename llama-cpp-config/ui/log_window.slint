// llama-server log viewer — an independent second root window (like AppTray),
// shown non-modally beside the main configurator: while it is open the main
// window stays fully interactive. Rust (src/gui/log_window.rs) tails
// logs\llama-server.log on a timer and pushes the retained text into
// `log_text`; after each push it invokes `scroll-to-end` so the view follows
// the file like `tail -f` — unless the user unticks Auto-scroll to read
// scrolled-back output while the server keeps writing.

import { TextEdit, CheckBox, Palette } from "std-widgets.slint";
import { Tokens } from "components.slint";

export component LogWindow inherits Window {
    title: "llama-server log";
    icon: @image-url("llama.png");
    min-width: 480px;
    min-height: 320px;
    preferred-width: 920px;
    preferred-height: 600px;
    background: Palette.background;

    // The retained tail of the log file, pushed from Rust on every poll that
    // found new bytes (never edited UI-side — the TextEdit below is read-only).
    in property <string> log_text;
    // The tailed file's path (display only, so the user can find the full file).
    in property <string> log_path;
    // Liveness readout, refreshed on every poll: file size + how long ago the
    // file last grew ("17.3 MB · updated 5 s ago"). llama-server can go quiet
    // for minutes between requests — without this a live tail over a silent
    // file is indistinguishable from a stuck one.
    in property <string> tail_status;
    // Owned by this window; Rust reads it to decide whether to follow the tail.
    in-out property <bool> auto_scroll: true;

    // Rust invokes this after pushing new text, passing the new text's UTF-8
    // length: parking the cursor at the very end makes the TextEdit scroll it
    // into view (there is no direct viewport control on the std TextEdit).
    public function scroll-to-end(len: int) {
        log-view.set-selection-offsets(len, len);
    }

    VerticalLayout {
        padding: 12px;
        spacing: 8px;

        HorizontalLayout {
            spacing: 12px;

            Text {
                text: root.log_path;
                font-size: 12px;
                color: Palette.foreground.transparentize(Tokens.faint);
                vertical-alignment: center;
                overflow: elide;
                horizontal-stretch: 1;
            }
            Text {
                text: root.tail_status;
                font-size: 12px;
                color: Palette.foreground.transparentize(Tokens.muted);
                vertical-alignment: center;
            }
            CheckBox {
                text: "Auto-scroll";
                checked <=> root.auto_scroll;
            }
        }

        // Read-only so the log stays selectable/copyable (Ctrl+C) but can't be
        // edited — same pattern as the chat-template preview and the Command
        // Line card.
        log-view := TextEdit {
            text: root.log_text;
            read-only: true;
            wrap: word-wrap;
            font-family: "Consolas";
            font-size: 12px;
            vertical-stretch: 1;
        }
    }
}
