// IntegrationsPage: the integrations tab. All state lives in AppState (state.slint).
//
// Layout (grep `heading:`): Models (toggle list) → OpenCode (status + buttons)
// → Claude Code card.

import { LineEdit, CheckBox, Button, ScrollView, Palette } from "std-widgets.slint";
import { SectionCard, LabeledField, Tokens } from "components.slint";
import { AppState } from "state.slint";

export component IntegrationsPage inherits ScrollView {
    VerticalLayout {
        padding: 24px;
        spacing: 16px;
        alignment: start;

        Text {
            text: "Integrations";
            font-size: 22px;
            font-weight: 600;
            color: Palette.foreground;
        }
        Text {
            text: "Expose presets as models in your AI coding tools. OpenCode is configured directly; Claude Code needs environment variables.";
            color: Palette.foreground.transparentize(Tokens.muted);
            font-size: 12px;
            wrap: word-wrap;
        }

        SectionCard {
            heading: "Models";
            content_padding: 8px;

            if AppState.integration_models.length == 0 : Text {
                text: "No presets found. Create presets under the Models tab first.";
                font-size: 12px;
                color: Palette.foreground.transparentize(Tokens.muted);
                wrap: word-wrap;
            }

            for item[i] in AppState.integration_models : Rectangle {
                height: 36px;
                // Tint with the WINDOW background: these rows sit on a
                // SectionCard, whose surface IS alternate-background — tinting
                // with the card's own colour composites to exactly itself.
                background: Math.mod(i, 2) == 0 ? transparent : Palette.background.transparentize(Tokens.zebra);

                HorizontalLayout {
                    padding-left: 12px;
                    padding-right: 12px;
                    spacing: 8px;
                    // Sanctioned one-way binding, with a real invariant behind
                    // it: clicking self-assigns `checked`, permanently breaking
                    // THIS delegate's binding. That stays invisible only because
                    // the sole in-place row write (toggle_integration_model)
                    // originates from this very widget; every other enabled-state
                    // change must rebuild the whole model (refresh_integrations)
                    // so the `for` delegates get fresh bindings. Details at the
                    // toggle handler in src/gui/integrations_tab.rs.
                    CheckBox {
                        text: "";
                        // Findable handle for the e2e rebuild-invariant phase
                        // (src/tests/save_flow.rs) — text is empty by design.
                        accessible-label: "integration-" + item.id;
                        checked: item.enabled;
                        toggled => { AppState.toggle_integration_model(i); }
                    }
                    Text {
                        text: item.id;
                        font-size: 13px;
                        font-weight: 600;
                        color: Palette.foreground;
                        vertical-alignment: center;
                        // Fixed-width first column so the label column below starts
                        // at the SAME x on every row — with stretch 0 on both texts
                        // the layout distributed the slack by the (variable) id width,
                        // so the labels rendered ragged. Same idiom as LabeledField's
                        // 130px label cell. min-width (not width) lets a longer-than-
                        // usual id take the room it needs rather than eliding.
                        min-width: 300px;
                        horizontal-stretch: 0;
                    }
                    Text {
                        text: item.label;
                        font-size: 11px;
                        color: Palette.foreground.transparentize(Tokens.muted);
                        vertical-alignment: center;
                        overflow: elide;
                        // Take all the remaining width and left-align (default), so
                        // the label column has one consistent left edge.
                        horizontal-stretch: 1;
                    }
                }
            }
        }

        SectionCard {
            heading: "OpenCode";
            LabeledField {
                label: "Status";
                Text {
                    text: AppState.integration_provider_active
                        ? "llama-server provider active in opencode.json"
                        : "No llama-server provider in opencode.json";
                    color: AppState.integration_provider_active ? Tokens.ok : Palette.foreground.transparentize(Tokens.muted);
                    font-size: 13px;
                    vertical-alignment: center;
                }
            }
            HorizontalLayout {
                spacing: 8px;
                Button {
                    text: "Save";
                    clicked => { AppState.save_integrations(); }
                }
                Button {
                    text: "Revert";
                    clicked => { AppState.revert_integrations(); }
                }
                Button {
                    text: "Open";
                    clicked => { AppState.open_opencode_folder(); }
                }
            }
        }

        SectionCard {
            heading: "Claude Code";
            content_padding: 12px;
            Text {
                text: "Claude Code uses environment variables to connect to a custom endpoint. Copy the snippet below and run it in PowerShell before launching Claude Code, or add it to your PROFILE.";
                wrap: word-wrap;
                font-size: 12px;
                color: Palette.foreground.transparentize(Tokens.muted);
            }
            LineEdit {
                text: AppState.integration_claude_env;
                read-only: true;
                font-size: 11px;
                horizontal-stretch: 1;
            }
        }
    }
}
