// Reusable visual pieces shared by the page components. Inventory:
// - globals: `Tokens` (canonical alpha levels), `Options` (shared option lists
//   + the `all_layers` slider bound)
// - layout/chrome: `SectionCard`, `LabeledField`, `InfoRow`, `FormActions`,
//   `ModalOverlay` (backdrop + card shared by all five app.slint modals)
// - inputs: `SegmentedControl`, `MappedComboBox` (label‚Üîvalue ComboBox),
//   `EnumComboBox` (string-valued ComboBox driven through current-index ‚Äî the
//   #11970-safe replacement for a `current-value` two-way binding),
//   `AutoSlider` (Slider + "default" checkbox, the push-binding pattern),
//   `DefaultSpinBox` / `DefaultLineEdit` (a "default" checkbox + an int SpinBox
//   / float LineEdit ‚Äî the "value, or omit the flag" pattern for numeric fields),
//   `GpuSplitTable` (the GPU distribution table ‚Äî which devices + what weights,
//   i.e. --device + --tensor-split + --split-mode; Server + Models tabs),
//   `TensorOverrideTable` (the tensor-placement table ‚Äî which tensors go on a
//   device of their own, i.e. --override-tensor; Models tab)
// - list rows/panels: `SelectableRow` / `AccentBar`, `ListPanel` (the bordered
//   list container around the preset list + the New/Clone model picker)

import { ComboBox, LineEdit, CheckBox, Slider, Button, Palette } from "std-widgets.slint";
import { GpuRow, TensorOverrideRow } from "types.slint";

// Canonical transparency levels for muted text and selection tints, so every
// page pulls from the same handful of values instead of eyeballing a new alpha.
// Used as `Palette.foreground.transparentize(Tokens.muted)` etc.
// Scope note: `Tokens` holds only cross-cutting alpha/color values. Layout
// metrics (body font-size 13px, the 130px label column, 8px card radius, 16px
// card padding) are deliberately kept inline at each use site ‚Äî not tokenized ‚Äî
// so this stays a color/alpha vocabulary, not a half-built design system.
export global Tokens {
    out property <float> subtle: 0.25;   // secondary text on a modal / high-contrast surface
    out property <float> muted: 0.4;     // page subtitles, help glyphs, "no results" notes
    out property <float> faint: 0.5;     // least-important text (paths, hints)
    out property <float> sel: 0.82;      // accent tint for a selected/active row
    out property <float> zebra: 0.3;     // alternate-row tint in striped lists

    // Semantic status colors (footer status message + run-state dot, integration
    // status). NB the footer run-state *text* is muted, not semantic (app.slint).
    // One home so an "error red" tweaked in one place can't drift from the others.
    out property <color> ok: #2e7d32;
    out property <color> err: #c62828;
    out property <color> off: #666666;

    // Overlay / elevation colors (the modal backdrop and the two drop-shadow
    // strengths ‚Äî cards vs the floating modal card).
    out property <color> backdrop: #000000.transparentize(0.45);
    out property <color> shadow-card: #00000022;
    out property <color> shadow-modal: #00000066;
}

// Canonical option lists reused by more than one page, so a new llama.cpp cache
// type or split mode is a one-line edit here instead of several scattered literal
// arrays that could drift.
export global Options {
    // "default" is a state, not a type: it OMITS --cache-type-k/-v and lets
    // llama.cpp pick (f16). It is not a synonym for the f16 entry ‚Äî that one
    // pins f16 whatever llama.cpp's default becomes. Same "empty string carried
    // as the word default" shape as `split_modes` below (form.rs maps both ways).
    out property <[string]> cache_types: ["default", "f32", "f16", "q8_0", "q5_0", "q4_0", "q4_1"];
    out property <[string]> split_modes: ["default", "none", "layer", "row"];
    // The -lv threshold, as "<name>:<level>". llama.cpp defines exactly these six
    // and a message prints when its own level is <= the threshold, so DEBUG:5 shows
    // everything and OUTPUT:0 almost nothing (`common/arg.cpp`, `common/log.h`).
    // A free number bought nothing but the chance to type a level that isn't one.
    // Mirrors LOG_LEVELS in src/server_form.rs ‚Äî the equality is asserted by the
    // e2e test (src/tests/ui_bindings.rs), so the two lists cannot drift.
    out property <[string]> log_levels: ["OUTPUT:0", "ERROR:1", "WARN:2", "INFO:3", "TRACE:4", "DEBUG:5"];
    // "All layers on GPU" sentinel for the --n-gpu-layers* flags: any value
    // above a real block count. Mirrors ALL_LAYERS in src/form.rs ‚Äî the
    // equality is asserted by the e2e test (src/tests/ui_bindings.rs).
    out property <int> all_layers: 99;
}

// The 3px accent bar marking the selected row ‚Äî shared by the nav rail
// (NavItem), the preset list, and the dialog model list so the selection visual
// is defined once. The caller sets `y`/`height` (a component root cannot reach
// `parent`, so the vertical inset lives at the use site).
export component AccentBar inherits Rectangle {
    x: 0;
    width: 3px;
    border-radius: 1.5px;
    background: Palette.accent-background;
}

// One row of a selectable list (the preset list, the New/Clone dialog's model
// list): selection tint + accent bar, hover highlight, a padded elided label,
// and a list-item accessibility role. `clicked` reports the activation; the
// CALLER owns the selection state (`selected` is a pure derived read, so the
// highlight follows the model even after clicks ‚Äî the same no-self-assignment
// rule as SegmentedControl). Set `height` at the use site.
export component SelectableRow inherits Rectangle {
    in property <string> label;
    in property <bool> selected;
    callback clicked();

    accessible-role: list-item;
    accessible-label: root.label;
    background: root.selected
        ? Palette.accent-background.transparentize(Tokens.sel)
        : (touch.has-hover ? Palette.background : transparent);

    if root.selected : AccentBar { y: 6px; height: parent.height - 12px; }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        Text {
            text: root.label;
            font-size: 12px;
            color: Palette.foreground;
            vertical-alignment: center;
            overflow: elide;
        }
    }
    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

// The bordered, rounded container the preset list and the New/Clone model
// picker both sit in: 1px border + 8px radius over the card surface, a muted
// placeholder Text when `is_empty`, and the caller's ListView as `@children`.
// One home for the chrome (and one row height at the use sites) so the two
// lists can't drift. The caller sets `min-height`/`vertical-stretch`.
export component ListPanel inherits Rectangle {
    in property <bool> is_empty;
    in property <string> empty_text;
    border-width: 1px;
    border-color: Palette.border;
    border-radius: 8px;
    background: Palette.alternate-background;
    if root.is_empty : Text {
        x: 16px;
        y: 16px;
        width: parent.width - 32px;
        text: root.empty_text;
        wrap: word-wrap;
        font-size: 12px;
        color: Palette.foreground.transparentize(Tokens.muted);
    }
    @children
}

// A ComboBox backed by parallel label/value arrays with a bounds-checked
// selection: `labels` drives the popup, `index` two-way-binds the current row,
// and `picked(value)` fires with `values[index]` ‚Äî guarded so an out-of-range
// index (e.g. an empty list) can never index past the array. The caller does the
// assignment and any side effects, keeping the write site visible.
export component MappedComboBox inherits ComboBox {
    in property <[string]> labels;
    in property <[string]> values;
    in-out property <int> index;
    callback picked(string);
    model: root.labels;
    current-index <=> root.index;
    selected => {
        if (self.current-index >= 0 && self.current-index < root.values.length) {
            root.picked(root.values[self.current-index]);
        }
    }
}

// A ComboBox over a fixed string option list, two-way-bound to a string `value`,
// driven through current-INDEX. Writing `current-value` does NOT move the
// selection (Slint #11970 ‚Äî it warns and leaves the dropdown stale on a model
// change), so the display is set via `current-index`, derived from `value`'s
// position in `options` and PUSHED on change (a plain binding dies on the first
// pick ‚Äî the std widget self-assigns current-index ‚Äî same class as AutoSlider's
// slider). A user pick writes the chosen string back through `value`. `value`
// should be a member of `options` (an unknown value shows the first entry).
export component EnumComboBox inherits ComboBox {
    in property <[string]> options;
    in-out property <string> value;
    // `value`'s position in `options`. Slint has no array index-of and no loops
    // inside functions, so this is an explicit scan bounded at 8 entries (the
    // longest option list here is cache_types = 7) ‚Äî extend the chain if a list
    // grows past 8. An out-of-range `options[i]` reads back as "" (never a real
    // `value`), so the tail branches stay inert.
    property <int> value_index: root.value == root.options[0] ? 0
        : root.value == root.options[1] ? 1
        : root.value == root.options[2] ? 2
        : root.value == root.options[3] ? 3
        : root.value == root.options[4] ? 4
        : root.value == root.options[5] ? 5
        : root.value == root.options[6] ? 6
        : root.value == root.options[7] ? 7
        : 0;
    model: root.options;
    current-index: root.value_index;
    selected => {
        root.value = self.current-value;
    }
    changed value_index => {
        if (self.current-index != root.value_index) {
            self.current-index = root.value_index;
        }
    }
}

// A "default" checkbox + a 0..maximum slider + a right-aligned readout ‚Äî the
// "count, or let llama.cpp decide" lever used for the layer-offload flags
// (--n-gpu-layers, --n-cpu-moe) and the CPU-thread counts (--threads,
// --threads-batch). `auto` (two-way; the on-screen label reads "default") omits
// the flag and disables the slider; `value` (two-way) is the count. The readout
// shows "default" when checked, else the count. The inner Slider's value is float and its
// own drag handler self-assigns it, so it can't be bound two-way to the int
// `value`: outward flows through `changed(v)`, inward through the
// `changed shown` push below (a plain `value:` binding dies on the first
// drag ‚Äî the recurring stale-widget class). `usable` gates the whole row on
// an external precondition (e.g. "model is MoE").
export component AutoSlider inherits HorizontalLayout {
    in-out property <bool> auto;
    in-out property <int> value;
    in property <int> maximum;
    in property <bool> usable: true;
    // Forwarded to the inner Slider's accessible-label so the e2e binding
    // test (src/tests/ui_bindings.rs) can find one instance and drive it.
    in property <string> slider_label;
    // The displayed count: the model value clamped to the slider range (a saved
    // 99 on a 48-layer model shows as 48). Shared by the slider and the readout.
    property <int> shown: Math.min(root.value, root.maximum);
    horizontal-stretch: 1;
    spacing: 8px;
    CheckBox {
        text: "default";
        enabled: root.usable;
        checked <=> root.auto;
    }
    sl := Slider {
        horizontal-stretch: 1;
        accessible-label: root.slider_label;
        enabled: !root.auto && root.usable;
        minimum: 0;
        maximum: root.maximum;
        value: root.shown;
        changed(v) => { root.value = Math.round(v); }
    }
    // Keep the thumb in sync with external value changes (preset switch,
    // Revert, GGUF-driven `maximum` change): the std Slider imperatively
    // overwrites its `value` on every drag, which permanently discards the
    // declarative init binding above ‚Äî so updates must be pushed. The guard
    // avoids re-entering while the drag itself round-trips through `shown`.
    changed shown => {
        if (sl.value != root.shown) {
            sl.value = root.shown;
        }
    }
    Text {
        // min-width, not a fixed width: the "default" string is wider than the
        // numeric readout it replaced and would clip in a fixed 44px cell.
        min-width: 44px;
        horizontal-alignment: right;
        vertical-alignment: center;
        text: root.auto ? "default" : "\{root.shown}";
    }
}

// A "default" checkbox + a LineEdit ‚Äî the ONE numeric field of both forms, for
// every "a number, or let llama.cpp decide" knob: the integers (ctx-size,
// parallel, batch-size, cache-ram, top-k, port, cache-reuse, models-max, ‚Ä¶) and
// the float sampling knobs (temp, top-p, min-p, repeat/presence-penalty) alike.
// `default` (two-way) omits the flag on save (None) and disables the field;
// `value` (two-way) is the text. Same shape as AutoSlider (auto checkbox +
// Slider): the checkbox carries the "unset" state, the input carries the value.
//
// When `default` is checked the field is disabled but still shows `value`, so
// preset_to_form seeds it with a display hint (form.rs's HINT_*) ‚Äî the user sees
// what they would get on unticking, and can edit straight away.
//
// THE INTEGERS RODE A SpinBox UNTIL v1.5.0, and the reason they no longer do is
// not cosmetic: Slint's `SpinBoxBase` puts a TouchArea over the whole widget whose
// `scroll-event` increments/decrements and always returns `accept` ‚Äî with no
// `has-focus` guard, unlike its own `ComboBoxBase`, which rejects a scroll it is
// not focused for. So merely wheeling the page with the pointer passing over a
// SpinBox silently edited the preset (and ate the scroll, so the page didn't even
// move). There is no property to disable it and no way to intercept the event
// (the TouchArea lives INSIDE the widget), so the fix is to stop using it: a
// LineEdit has no scroll handler at all. `input_type` is what makes it an integer
// field ‚Äî `number` accepts ASCII digits ONLY (i-slint-core `accept_text_input`),
// so no `40.5` can slip a `parse_int`, which is what the SpinBox used to buy us.
// The two exceptions are the fields that must accept a leading `-` (cache-ram's
// `-1` = no limit) and the floats: `decimal` also allows the sign and the decimal
// separator, and Rust re-checks the text either way (`ini::parse_int` /
// `parse_float`, the latter normalizing a comma).
export component DefaultLineEdit inherits HorizontalLayout {
    in-out property <bool> default;
    in-out property <string> value;
    in property <string> placeholder;
    // Forwarded to the inner LineEdit's accessible-label so the e2e binding
    // test (src/tests/ui_bindings.rs) can find and drive one instance.
    in property <string> edit_label;
    // Gates the whole row on an external precondition (e.g. "a draft is
    // selected"), matching AutoSlider's `usable`.
    in property <bool> enabled: true;
    // `number` = integers (digits only); `decimal` = signed / fractional.
    in property <InputType> input_type: InputType.decimal;
    spacing: 8px;
    CheckBox {
        text: "default";
        enabled: root.enabled;
        checked <=> root.default;
    }
    LineEdit {
        horizontal-stretch: 1;
        accessible-label: root.edit_label;
        enabled: !root.default && root.enabled;
        text <=> root.value;
        input-type: root.input_type;
        placeholder-text: root.placeholder;
    }
}

// A titled card: an optional `heading` over a bordered, subtly-elevated body
// (rounded rectangle + drop shadow) wrapping `@children`. `content_padding`
// tunes the inner inset (16px default). This is the section container every
// tab groups its form fields into.
export component SectionCard {
    in property <string> heading;
    in property <length> content_padding: 16px;

    VerticalLayout {
        spacing: 8px;

        if root.heading != "" : Text {
            text: root.heading;
            font-size: 13px;
            font-weight: 600;
            color: Palette.foreground;
        }

        Rectangle {
            border-radius: 8px;
            border-width: 1px;
            border-color: Palette.border;
            background: Palette.alternate-background;
            // Subtle elevation (Skia renderer only).
            drop-shadow-color: Tokens.shadow-card;
            drop-shadow-blur: 10px;
            drop-shadow-offset-y: 2px;

            VerticalLayout {
                padding: root.content_padding;
                spacing: 10px;
                @children
            }
        }
    }
}

// A horizontal set of mutually-exclusive pills ‚Äî a reactive replacement for a
// `RadioGroup` in a form. The selected state is a PURE derived read of `current`
// (supplied by the caller as a binding); this component never assigns a bound
// property imperatively, so ‚Äî unlike `RadioButton.checked` ‚Äî the caller's binding
// is never broken and the highlight follows `current` even after the user clicks
// (e.g. when the backing model is swapped on a preset switch). Clicks are reported
// via `activated`; the caller writes the model.
export component SegmentedControl inherits HorizontalLayout {
    in property <[string]> options;
    in property <string> current;
    // Grey out + swallow clicks when false (dims like a disabled std widget).
    in property <bool> enabled: true;
    callback activated(string);
    spacing: 6px;
    opacity: root.enabled ? 1.0 : 0.4;
    for opt in root.options : Rectangle {
        // Surface the pill to assistive tech (and to the headless UI test's
        // accessible-label lookup) ‚Äî a bare Rectangle+TouchArea is invisible.
        accessible-role: button;
        accessible-label: opt;
        accessible-checkable: true;
        accessible-checked: opt == root.current;
        height: 30px;
        min-width: 60px;
        border-radius: 6px;
        border-width: 1px;
        border-color: opt == root.current ? Palette.accent-background : Palette.border;
        background: opt == root.current
            ? Palette.accent-background.transparentize(Tokens.sel)
            : (touch.has-hover ? Palette.alternate-background : transparent);
        HorizontalLayout {
            padding-left: 12px;
            padding-right: 12px;
            Text {
                text: opt;
                vertical-alignment: center;
                horizontal-alignment: center;
                horizontal-stretch: 1;
                font-size: 13px;
                font-weight: opt == root.current ? 600 : 400;
                color: opt == root.current ? Palette.accent-background : Palette.foreground;
            }
        }
        touch := TouchArea {
            enabled: root.enabled;
            mouse-cursor: pointer;
            clicked => { root.activated(opt); }
        }
    }
}

// The two-column form row every labeled input sits in: a fixed 130px `label`
// column (with an optional ‚ìò hover `hint`) on the left, the stretched field
// `@children` on the right.
export component LabeledField inherits HorizontalLayout {
    in property <string> label;
    // Optional hover help. When set, an ‚ìò glyph is shown after the label and
    // carries a Tooltip ‚Äî keeps long explanations out of the input placeholders.
    in property <string> hint;
    spacing: 8px;
    alignment: stretch;
    HorizontalLayout {
        width: 130px;
        spacing: 4px;
        alignment: start;
        Text {
            text: root.label;
            vertical-alignment: center;
            font-size: 13px;
            // Elide instead of overflowing onto the field when the label is long;
            // horizontal-stretch lets the ‚ìò keep its own cell on the right.
            overflow: elide;
            horizontal-stretch: 1;
        }
        if root.hint != "" : Text {
            text: "\u{E946}";
            font-family: "Segoe Fluent Icons";
            font-size: 13px;
            // Fixed-width cell so the glyph is always visible and gives the
            // Tooltip a reliable hover target ‚Äî inside a 130px label row a
            // stretched/0-width cell would collapse and never trigger hover.
            width: 16px;
            horizontal-stretch: 0;
            horizontal-alignment: center;
            vertical-alignment: center;
            color: Palette.foreground.transparentize(Tokens.muted);
            // Custom content (a plain Text) avoids the styled-text/@markdown
            // conversion that Tooltip.text would require for a string property.
            // It MUST be wrapped in a layout: ToolTipImpl is a plain Rectangle
            // and does not lay out a bare fixed-width child, so the popup stays
            // ~padding-wide and the text spills off its right edge. A layout
            // propagates the 300px width up so the Rectangle sizes to it.
            Tooltip {
                VerticalLayout {
                    padding: 10px;
                    Text { text: root.hint; wrap: word-wrap; width: 300px; font-size: 14px; }
                }
            }
        }
    }
    @children
}

// A read-only `label ‚Üí value` row for the "Model info" card: a LabeledField
// whose body is one wrapped, foreground-coloured Text. Collapses the repeated
// `LabeledField { Text { ‚Ä¶six identical props‚Ä¶ } }` boilerplate to a single
// line per fact. `label`/`hint` are inherited from LabeledField.
export component InfoRow inherits LabeledField {
    in property <string> value;
    Text {
        text: root.value;
        vertical-alignment: center;
        font-size: 13px;
        wrap: word-wrap;
        horizontal-stretch: 1;
        color: Palette.foreground;
    }
}

// A centered modal card floating over a full-screen dim backdrop. Clicking the
// backdrop (or pressing Escape) fires `dismissed`; the card swallows its own
// clicks (the empty inner TouchArea) so a click inside doesn't dismiss. The
// title + optional description are laid out first, then the caller's
// body/buttons via `@children`. Collapses the ~30 lines of identical chrome
// each dialog in app.slint used to repeat.
export component ModalOverlay inherits Rectangle {
    in property <string> title;
    in property <string> description;
    in property <length> card_width: 440px;
    in property <length> card_height: 220px;
    callback dismissed();

    z: 1;
    width: 100%;
    height: 100%;
    background: Tokens.backdrop;
    TouchArea {
        clicked => { root.dismissed(); }
    }
    // Escape dismisses. The scope wraps the card so a key the focused child
    // widget doesn't handle bubbles up here; it also takes focus when the
    // dialog opens (a child's own `init => focus()` ‚Äî e.g. a dialog's text
    // field ‚Äî runs after and wins, which is the desired order).
    FocusScope {
        init => { self.focus(); }
        key-pressed(event) => {
            if (event.text == Key.Escape) {
                root.dismissed();
                return accept;
            }
            reject
        }
        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: root.card_width;
            height: root.card_height;
            background: Palette.background;
            border-radius: 10px;
            border-width: 1px;
            border-color: Palette.border;
            drop-shadow-color: Tokens.shadow-modal;
            drop-shadow-blur: 24px;
            drop-shadow-offset-y: 6px;
            TouchArea { }
            VerticalLayout {
                padding: 22px;
                spacing: 12px;
                Text {
                    text: root.title;
                    font-size: 16px;
                    font-weight: 700;
                    color: Palette.foreground;
                }
                if root.description != "" : Text {
                    text: root.description;
                    wrap: word-wrap;
                    font-size: 12px;
                    color: Palette.foreground.transparentize(Tokens.subtle);
                }
                @children
            }
        }
    }
}

// The action row every tab ends with: right-aligned Revert + primary Save.
// One home so the three tabs' rows can't drift ‚Äî the save-button text and the
// two enabled gates are the only per-tab differences.
export component FormActions inherits HorizontalLayout {
    in property <string> save_text: "Save";
    in property <bool> save_enabled: true;
    in property <bool> revert_enabled: true;
    callback save();
    callback revert();
    alignment: end;
    spacing: 8px;
    Button {
        text: "Revert";
        enabled: root.revert_enabled;
        clicked => { root.revert(); }
    }
    Button {
        text: root.save_text;
        primary: true;
        enabled: root.save_enabled;
        clicked => { root.save(); }
    }
}

// The GPU distribution table: which devices a model runs on and in what
// proportion, shared by the Server tab (server-wide default) and the Models tab
// (per-preset override). It replaces what used to be a single-select "GPU device"
// ComboBox plus a free-text "Tensor split" LineEdit ‚Äî two fields that only make
// sense read together, because `--tensor-split` is a positional vector indexed
// over the devices named by `--device`, in `--device` order. Typing `3,1` against
// an unseen, unchosen device list (six entries on a CUDA+ROCm box, half of them
// duplicate Vulkan views) is guesswork; a table isn't.
//
// Rust owns everything: `rows`, `summary`, `selected` and `weight_total` are all
// pushed from src/gpu_split.rs, which renders the selection back into the form's
// `device` + `tensor_split` strings. The .slint side only reports edits, and it
// addresses devices BY ID, never by row index.
//
// The checked rows come FIRST, in split order: read top to bottom they ARE the
// --device list and its --tensor-split vector. That is what makes the ‚â° drag
// handle mean something ‚Äî and position 0 is not cosmetic, it is llama.cpp's
// main_gpu (the sole GPU under --split-mode none, the first slice of layers under
// layer). Checking a box APPENDS the device at the end of the split; the handle
// is how you promote it. Nothing reorders on its own.
//
// BINDING NOTE (the sanctioned one-way `for`-row exception, same as the
// Integrations checkboxes): `checked: row.enabled` and `text: row.weight` are
// one-way, and a click/edit self-assigns them, permanently breaking THAT
// delegate's binding. Two rules keep that invisible:
//   1. toggle / Auto / Even / preset switch / device probe REBUILD the whole row
//      model, so every delegate gets a fresh binding (gui::refresh_gpu_rows).
//   2. a weight edit changes no OTHER row's weight, so it needs no rebuild at
//      all ‚Äî which is exactly why the weight fields stay disabled in Auto mode
//      (leaving Auto seeds every weight; that's what the Even button is for).
// The share column reads the field's LIVE text (`w.text`), not `row.weight`, so
// it keeps up with a broken-binding delegate.
export component GpuSplitTable inherits VerticalLayout {
    in property <[GpuRow]> rows;
    in property <string> summary;
    // Checked devices, and the sum of their weights (0 = Auto: a blank
    // --tensor-split, which llama.cpp fills in from each device's FREE VRAM at
    // load time ‚Äî not an even split).
    in property <int> selected;
    in property <int> weight_total;
    // Non-empty to show a warning strip above the table (the Models tab uses it
    // for "a server-wide selection overrides this one at launch").
    in property <string> warning;
    in property <string> split_mode_hint;
    in-out property <string> split_mode;
    callback toggled(string);
    // Drag-handle result: move this device `delta` places within the split
    // (negative = up / towards the head). Reported ONCE, on release: the drag
    // itself is a pure visual preview (`row_y` below), because rebuilding the row
    // model mid-drag would recreate this delegate and drop the TouchArea's grab.
    callback reordered(string, int);
    callback weight_edited(string, int);
    callback auto_split();
    callback even_split();

    property <bool> weights_editable: root.selected >= 2 && root.weight_total > 0;
    // One home for the row height: it lays the rows out, and it is the divisor
    // that turns a drag distance into a row delta. They must not drift.
    property <length> row_height: 40px;

    // Live-drag state. Set by the handle's TouchArea while it is held, cleared on
    // release. Only `row_y` reads it ‚Äî the row MODEL never changes during a drag.
    property <string> drag_id: "";
    property <int> drag_from: 0;
    property <length> drag_dy: 0;

    // Where the dragged row would land: its own index plus the rows of travel,
    // clamped to the checked block (the only rows with a position in the split).
    pure function drag_target() -> int {
        Math.max(0, Math.min(root.selected - 1,
            root.drag_from + Math.round(root.drag_dy / root.row_height)))
    }

    // The rows are positioned by hand rather than by a layout so a drag can move
    // them: the held row follows the pointer, and the rows it passes slide one slot
    // to open the gap. Nothing here is committed ‚Äî `reordered` on release is.
    pure function row_y(i: int, id: string) -> length {
        if (root.drag_id == "") {
            return i * root.row_height;
        }
        if (root.drag_id == id) {
            return root.drag_from * root.row_height + root.drag_dy;
        }
        // Unchecked rows sit below the split and never take part.
        if (i >= root.selected) {
            return i * root.row_height;
        }
        if (i > root.drag_from && i <= root.drag_target()) {
            return (i - 1) * root.row_height;   // dragging down: shift up
        }
        if (i >= root.drag_target() && i < root.drag_from) {
            return (i + 1) * root.row_height;   // dragging up: shift down
        }
        return i * root.row_height;
    }

    pure function share_text(enabled: bool, weight: int) -> string {
        if (!enabled) {
            return "‚Äî";
        }
        if (root.selected < 2) {
            return "100%";
        }
        if (root.weight_total <= 0) {
            return "auto";
        }
        return "\{Math.round(weight * 100 / root.weight_total)}%";
    }

    spacing: 10px;

    if root.warning != "" : Text {
        text: root.warning;
        wrap: word-wrap;
        font-size: 12px;
        color: Tokens.err;
    }

    // Header row. Column widths are repeated verbatim by the delegate below ‚Äî
    // there is no grid here, just two HorizontalLayouts kept in step by hand.
    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 8px;
        Rectangle { width: 24px; }
        Rectangle { width: 18px; }
        Text {
            text: "Device";
            horizontal-stretch: 1;
            font-size: 12px;
            color: Palette.foreground.transparentize(Tokens.muted);
        }
        Text {
            width: 120px;
            text: "VRAM";
            font-size: 12px;
            color: Palette.foreground.transparentize(Tokens.muted);
        }
        Text {
            width: 84px;
            text: "Weight";
            font-size: 12px;
            color: Palette.foreground.transparentize(Tokens.muted);
        }
        Text {
            width: 52px;
            text: "Share";
            horizontal-alignment: right;
            font-size: 12px;
            color: Palette.foreground.transparentize(Tokens.muted);
        }
    }

    if root.rows.length == 0 : Text {
        text: "Detecting GPUs‚Ä¶";
        font-size: 13px;
        color: Palette.foreground.transparentize(Tokens.muted);
    }

    // Hand-positioned rows (see `row_y`), so a drag can slide them. Height is the
    // whole block, since the enclosing VerticalLayout can't measure absolute children.
    Rectangle {
        height: root.rows.length * root.row_height;
        for row[i] in root.rows : Rectangle {
            x: 0;
            y: root.row_y(i, row.id);
            width: parent.width;
            height: root.row_height;
            // Tint with the WINDOW background: these rows sit on a SectionCard, whose
            // surface IS alternate-background ‚Äî tinting with the card's own colour
            // would composite to exactly itself. Same trick as integrations_page.
            // Opaque while held, so the dragged row reads as floating over the others.
            background: grip.pressed ? Palette.alternate-background
                : (Math.mod(i, 2) == 0 ? transparent : Palette.background.transparentize(Tokens.zebra));
            border-radius: grip.pressed ? 4px : 0;
            drop-shadow-color: grip.pressed ? Tokens.shadow-card : transparent;
            drop-shadow-blur: 8px;
    
            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                padding-top: 4px;
                padding-bottom: 4px;
                spacing: 8px;
    
                CheckBox {
                    width: 24px;
                    text: "";
                    // Findable handle for the e2e table phase (src/tests/save_flow.rs)
                    // ‚Äî text is empty by design.
                    accessible-label: "gpu-" + row.id;
                    checked: row.enabled;
                    toggled => {
                        root.toggled(row.id);
                    }
                }
    
                // Drag handle. Only checked rows have a position in the split, and with
                // a single device there is nothing to order. While held it feeds the
                // live preview (`drag_*` ‚Üí `row_y`); on release it reports the move
                // once, and the resulting model rebuild is what actually moves the row.
                Rectangle {
                    width: 18px;
                    Text {
                        x: 0;
                        y: 0;
                        width: parent.width;
                        height: parent.height;
                        visible: row.enabled && root.selected >= 2;
                        text: "‚â°";
                        font-size: 15px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        color: Palette.foreground.transparentize(grip.has-hover ? 0 : Tokens.faint);
                    }
                    grip := TouchArea {
                        enabled: row.enabled && root.selected >= 2;
                        mouse-cursor: grip.pressed ? MouseCursor.grabbing : MouseCursor.grab;
                        moved => {
                            root.drag_id = row.id;
                            root.drag_from = i;
                            root.drag_dy = self.mouse-y - self.pressed-y;
                        }
                        pointer-event(ev) => {
                            if (ev.kind == PointerEventKind.up && root.drag_id == row.id) {
                                root.reordered(row.id, root.drag_target() - root.drag_from);
                                root.drag_id = "";
                                root.drag_dy = 0;
                            }
                        }
                    }
                }
    
                HorizontalLayout {
                    horizontal-stretch: 1;
                    spacing: 8px;
                    Text {
                        width: 64px;
                        text: row.id;
                        vertical-alignment: center;
                        font-size: 13px;
                        font-weight: 600;
                        color: Palette.foreground;
                    }
                    Text {
                        text: row.name;
                        vertical-alignment: center;
                        font-size: 13px;
                        overflow: elide;
                        horizontal-stretch: 1;
                        // A selected device the probe doesn't know (stale config, or
                        // the probe hasn't landed) reads as an absence, not a GPU.
                        color: row.detected
                            ? Palette.foreground
                            : Palette.foreground.transparentize(Tokens.faint);
                    }
                }
    
                Text {
                    width: 120px;
                    text: row.vram;
                    vertical-alignment: center;
                    font-size: 13px;
                    color: Palette.foreground.transparentize(Tokens.faint);
                }
    
                Rectangle {
                    width: 84px;
                    // A LineEdit, not a SpinBox, for the reason spelled out on
                    // DefaultLineEdit: a SpinBox here turned a scroll of the page
                    // into a silent edit of the split. `number` keeps it digits-
                    // only now that there is no minimum/maximum to lean on; the
                    // value is re-checked in Rust (gpu_split::set_weight).
                    w := LineEdit {
                        x: 0;
                        y: 0;
                        width: parent.width;
                        height: parent.height;
                        visible: row.enabled;
                        enabled: root.weights_editable;
                        input-type: InputType.number;
                        text: row.weight;
                        edited(t) => {
                            root.weight_edited(row.id, t.to-float());
                        }
                    }
                    Text {
                        width: parent.width;
                        height: parent.height;
                        visible: !row.enabled;
                        text: "‚Äî";
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        font-size: 13px;
                        color: Palette.foreground.transparentize(Tokens.faint);
                    }
                }
    
                Text {
                    width: 52px;
                    text: root.share_text(row.enabled, w.text.to-float());
                    horizontal-alignment: right;
                    vertical-alignment: center;
                    font-size: 13px;
                    color: Palette.foreground;
                }
            }
        }
    }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 8px;
        Button {
            text: "Auto";
            enabled: root.selected >= 2 && root.weight_total > 0;
            clicked => {
                root.auto_split();
            }
        }
        Button {
            text: "Even";
            enabled: root.selected >= 2;
            clicked => {
                root.even_split();
            }
        }
        Text {
            text: root.summary;
            vertical-alignment: center;
            horizontal-stretch: 1;
            overflow: elide;
            font-size: 12px;
            color: Palette.foreground.transparentize(Tokens.faint);
        }
    }

    LabeledField {
        label: "GPU split mode";
        hint: root.split_mode_hint;
        EnumComboBox {
            // One device has nothing to split. Zero means "all detected devices",
            // which llama.cpp still splits ‚Äî so the combo stays live there.
            // `split_mode` is never "" (the form conversions map empty ‚Üí
            // "default"), or the ComboBox would show a blank current row.
            enabled: root.selected != 1;
            options: Options.split_modes;
            value <=> root.split_mode;
        }
    }
}

// The tensor-placement table: `--override-tensor` as (what ‚Üí where) rows instead
// of a `<regex>=<device>,‚Ä¶` string. Rows come from Rust (src/tensor_override.rs),
// which owns every rule; this component only reports edits, addressed by ROW
// INDEX (the same pattern may appear twice, so there is no id to name one by).
//
// Why the pattern is a dropdown and not just a text field: llama.cpp splits the
// value on `,` and each rule at its FIRST `=` BEFORE it parses anything, and
// neither is escapable ‚Äî so a hand-typed regex with a `{1,2}` quantifier tears
// its own rule in half and the model fails to load. The three canned patterns
// cover what people actually reach for; `Custom regex‚Ä¶` reveals the text field,
// which strips those two characters on the Rust side.
//
// BINDING NOTE (the sanctioned one-way `for`-row exception, as in GpuSplitTable):
// `index: row.kind_index` / `index: row.device_index` / `text: row.pattern` are
// one-way, and a pick/keystroke self-assigns them, permanently breaking THAT
// delegate's binding. Two rules keep that invisible:
//   1. add / remove / kind / device REBUILD the whole row model, so every
//      delegate gets a fresh binding (gui::refresh_tensor_rows).
//   2. a pattern edit changes no OTHER row, so it needs no rebuild at all ‚Äî and
//      MUST not do one, or the LineEdit being typed into would be recreated and
//      drop the caret. Its handler refreshes the derived strings only.
export component TensorOverrideTable inherits VerticalLayout {
    in property <[TensorOverrideRow]> rows;
    in property <string> summary;
    // The two shared dropdown models: the canned patterns (last = "Custom regex‚Ä¶")
    // and the probed devices, CPU included ‚Äî it is a legal -ot target.
    in property <[string]> kind_labels;
    in property <[string]> kind_values;
    in property <[string]> dev_labels;
    in property <[string]> dev_values;
    // Non-empty to show a warning strip above the table (a value llama.cpp would
    // refuse to parse ‚Äî only a hand-edited INI can produce one).
    in property <string> warning;
    // A SECOND, independent strip: these rules are shadowed at launch by a
    // server-wide value (the Models tab's copy passes AppState.tensor_override_warning).
    // Independent because a table can be both invalid AND shadowed, and the two
    // say different things ‚Äî one is "llama.cpp will refuse this", the other is
    // "llama.cpp will never see this".
    in property <string> override_warning;

    callback added();
    callback removed(int);
    callback kind_picked(int, string);
    callback device_picked(int, string);
    callback pattern_edited(int, string);

    spacing: 10px;

    if root.override_warning != "" : Text {
        text: root.override_warning;
        wrap: word-wrap;
        font-size: 12px;
        color: Tokens.err;
    }

    if root.warning != "" : Text {
        text: root.warning;
        wrap: word-wrap;
        font-size: 12px;
        color: Tokens.err;
    }

    // Header. Column widths are repeated verbatim by the delegate below ‚Äî there
    // is no grid here, just two HorizontalLayouts kept in step by hand.
    if root.rows.length > 0 : HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 8px;
        Text {
            text: "Tensor";
            horizontal-stretch: 1;
            font-size: 12px;
            color: Palette.foreground.transparentize(Tokens.muted);
        }
        Text {
            width: 260px;
            text: "Goes on";
            font-size: 12px;
            color: Palette.foreground.transparentize(Tokens.muted);
        }
        Rectangle { width: 36px; }
    }

    for row[i] in root.rows : Rectangle {
        // Tint with the WINDOW background: these rows sit on a SectionCard, whose
        // surface IS alternate-background ‚Äî tinting with the card's own colour
        // would composite to exactly itself. Same trick as GpuSplitTable.
        background: Math.mod(i, 2) == 0 ? transparent
            : Palette.background.transparentize(Tokens.zebra);

        VerticalLayout {
            padding-left: 12px;
            padding-right: 12px;
            padding-top: 4px;
            padding-bottom: 4px;
            spacing: 4px;

            HorizontalLayout {
                spacing: 8px;

                MappedComboBox {
                    horizontal-stretch: 1;
                    // Findable handle for the e2e table phase (src/tests/save_flow.rs).
                    accessible-label: "ot-kind-" + i;
                    labels: root.kind_labels;
                    values: root.kind_values;
                    index: row.kind_index;
                    picked(v) => {
                        root.kind_picked(i, v);
                    }
                }

                MappedComboBox {
                    width: 260px;
                    accessible-label: "ot-device-" + i;
                    labels: root.dev_labels;
                    values: root.dev_values;
                    // -1 when the rule names no device: the ComboBox then shows a
                    // blank row, and `row.problem` says "pick a device".
                    index: row.device_index;
                    picked(v) => {
                        root.device_picked(i, v);
                    }
                }

                Button {
                    width: 36px;
                    // U+00D7, which Segoe UI HAS. It shipped once as "‚úï" (U+2715,
                    // Dingbats), which Segoe UI does not have and nothing falls back
                    // for: a correctly laid out, perfectly empty box. The icon-font
                    // escape LabeledField's hint uses (`\u{E711}` +
                    // `font-family: "Segoe Fluent Icons"`) is NOT available here ‚Äî
                    // std Button has no font-family property, only Text does ‚Äî so a
                    // button's label is stuck with the default font, and its glyph
                    // must be one that font covers. Guarded by
                    // `slint_string_literals_only_use_glyphs_proven_to_render`.
                    text: "√ó";
                    clicked => {
                        root.removed(i);
                    }
                }
            }

            // Only the Custom kind gets a text field ‚Äî every other row's pattern
            // is a canned constant, and letting it be edited would just be a
            // slower way of picking Custom.
            if row.custom : LineEdit {
                accessible-label: "ot-pattern-" + i;
                placeholder-text: "regex matched against tensor names, e.g. blk\\.1[0-9]\\..*_exps";
                text: row.pattern;
                edited(t) => {
                    root.pattern_edited(i, t);
                }
            }

            if row.problem != "" : Text {
                text: row.problem;
                font-size: 12px;
                color: Tokens.err;
            }
        }
    }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 8px;
        Button {
            text: "+ Add override";
            clicked => {
                root.added();
            }
        }
        Text {
            text: root.summary;
            vertical-alignment: center;
            horizontal-stretch: 1;
            overflow: elide;
            font-size: 12px;
            color: Palette.foreground.transparentize(Tokens.faint);
        }
    }
}
